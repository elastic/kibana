        "id": "def-common.slugify",
        "type": "Function",
        "tags": [
          "throws"
        ],
        "label": "slugify",
        "description": [
          "\nConverts a user-provided name into a safe, lowercase identifier suitable for\nworkflow name prefixes, tool ID segments, and MCP namespaces.\n\nApplies the minimum transformation required by the strictest downstream\nconstraint (tool IDs: lowercase `[a-z0-9_-]`, segments start/end with `[a-z0-9]`).\n"
        ],
        "signature": [
          "(input: string) => string"
