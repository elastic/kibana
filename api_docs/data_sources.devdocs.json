        "id": "def-common.getWorkflowPrefix",
        "type": "Function",
        "tags": [],
        "label": "getWorkflowPrefix",
        "description": [
          "\nReturns the prefix shared by all workflow names belonging to a data source.\nUsed by the server to build full workflow names and by the UI to build\nsearch queries that filter workflows for a specific data source.\n\nFormat: `{name}.{type}.source` -- extends the tool prefix with `.source.`\nso that workflow names and workflow tool IDs are identical.\n\nFull workflow name: `{workflowPrefix}.{workflowBaseName}`"
        ],
        "signature": [
          "(name: string, type: string) => string"
        ],
