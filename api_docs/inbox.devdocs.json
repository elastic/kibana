    "interfaces": [
      {
        "parentPluginId": "inbox",
        "id": "def-server.InboxActionConflictError",
        "type": "Interface",
        "tags": [],
        "label": "InboxActionConflictError",
        "description": [
          "\nSignals that an inbox action exists in our addressing scheme but is no\nlonger in a state that can accept a response — the underlying resource\n(e.g. a workflow step) has already been advanced, cancelled, or\nclaimed by another responder.\n\nProvider implementations throw this so the framework can surface a\nstable HTTP 409 Conflict back to the caller instead of a generic 500.\nThat, in turn, lets clients (UI, MCP, evals) distinguish \"the action\nis gone, refresh your inbox\" from a real server error.\n\nModeled as an `interface` + factory + type guard (rather than a\nsubclass) to mirror the colocated `UnknownInboxSourceAppError` and\nkeep this file under the `max-classes-per-file` lint cap."
        ],
        "signature": [
          {
            "pluginId": "inbox",
            "scope": "server",
            "docId": "kibInboxPluginApi",
            "section": "def-server.InboxActionConflictError",
