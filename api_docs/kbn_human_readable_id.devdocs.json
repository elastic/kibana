        "id": "def-common.buildCandidateIds",
        "type": "Function",
        "tags": [],
        "label": "buildCandidateIds",
        "description": [
          "\nBuilds the list of candidate IDs for a given base ID:\n[baseId, baseId-1, baseId-2, ..., baseId-{MAX_COLLISION_RETRIES}].\n\nWhen a base ID is near HUMAN_READABLE_ID_MAX_LENGTH and already ends with a\nhyphen-digit pattern (e.g. `<252 chars>-1`), truncation + re-suffixing\ncan reconstruct the original base, producing a duplicate entry. Duplicates\nare skipped so every element in the returned array is unique."
        ],
        "signature": [
          "(baseId: string) => string[]"
        ],
