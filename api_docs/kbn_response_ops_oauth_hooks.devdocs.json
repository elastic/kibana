      {
        "parentPluginId": "@kbn/response-ops-oauth-hooks",
        "id": "def-public.useConnectorOAuthConnect",
        "type": "Function",
        "tags": [],
        "label": "useConnectorOAuthConnect",
        "description": [
          "\nInitiates the OAuth authorization code grant flow for a connector\n(via `connect()`).\n\nIn `NewTab` mode, the hook listens for flow completion and invokes\n`onSuccess`/`onError` callbacks. `isAwaitingCallback` is `true` while waiting\nfor the user to complete authorization in the other tab, and resets after flow\ncompletion or after `timeout` elapses.\n\nIn `Redirect` mode, the page navigates away. `onSuccess` and\n`isAwaitingCallback` are not applicable.\n\nWhen `returnUrl` is provided, the OAuth callback redirects to that URL with\nresult query parameters (requires `useOAuthRedirectResult` at that page).\nWhen omitted, the callback renders a self-contained HTML page."
        ],
        "signature": [
          "({ connectorId, redirectMode, returnUrl, timeout, onSuccess, onError, }: ",
          {
            "pluginId": "@kbn/response-ops-oauth-hooks",
            "scope": "public",
            "docId": "kibKbnResponseOpsOauthHooksPluginApi",
            "section": "def-public.ConnectorOAuthConnectProps",
            "text": "ConnectorOAuthConnectProps"
          },
