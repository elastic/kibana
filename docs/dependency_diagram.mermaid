%% Security Detection Spikes - Dependency Diagram
%% Import into Miro: File > Import > choose this .mmd file
%% Or paste into https://mermaid.live for editing

graph TB
    subgraph tier1["TIER 1: Platform Foundations (Week 1-2)<br/>@detection-engine + @generative-ai"]
        A1["Rule Type Registry<br/><br/>What: Register new rule types<br/>Blocks: All rule execution"]
        A2["Alert Schema<br/><br/>What: TypeScript types for alerts<br/>Blocks: Correlation, Vuln Checker"]
        A3["AI Constants<br/><br/>What: Batch size, thresholds<br/>Blocks: Pipeline"]
        A4["Test Infrastructure<br/><br/>What: E2E test utilities<br/>Blocks: All testing"]
    end

    subgraph tier2["TIER 2: New Detection Capabilities (Week 3-4)<br/>@detection-engine"]
        B1["Correlation Engine<br/><br/>What: ES|QL cross-alert queries<br/>Value: Detect attack chains"]
        B2["Vulnerability Detection<br/><br/>What: CVE matching + AI triage<br/>Value: Proactive vuln mgmt"]
    end

    subgraph tier3["TIER 3: Plugin Features (Week 5-8, PARALLEL)"]
        C1["Compliance Monitoring<br/>@defend-workflows<br/><br/>What: CIS benchmark checks<br/>Value: Compliance dashboard"]
        C2["Alert Pipeline<br/>@generative-ai<br/><br/>What: Dedup + case creation<br/>Value: Reduce alert fatigue"]
        C3["Hierarchical Batch<br/>@generative-ai<br/><br/>What: LLM batch processing<br/>Value: OSS model support"]
    end

    subgraph tier4["TIER 4: Integration (Week 9-12)<br/>ALL teams"]
        D1["Workflows Integration<br/><br/>Compose detection → correlation → case<br/>Coordination: Weekly syncs"]
        D2["Cases Auto-Creation<br/><br/>Pipeline → Cases plugin<br/>Coordination: Bi-weekly syncs"]
        D3["UI Components<br/><br/>Flyouts, dashboards, forms<br/>Coordination: Monthly reviews"]
    end

    subgraph external["External Dependencies"]
        E1["Cases Plugin<br/>@kibana-cases"]
        E2["Fleet Plugin<br/>Fleet team"]
        E3["Workflows Plugin<br/>Workflows team"]
    end

    %% Tier 1 → Tier 2 dependencies
    A1 --> B1
    A1 --> B2
    A2 --> B1
    A2 --> B2

    %% Tier 1 → Tier 3 dependencies
    A1 --> C1
    A3 --> C2
    A3 --> C3

    %% Tier 2 → Tier 3 dependencies
    B1 --> C2
    B2 --> C2

    %% Tier 3 → Tier 4 dependencies
    C1 --> D1
    C2 --> D1
    C2 --> D2
    C3 --> D2

    %% Tier 4 → External dependencies
    D1 --> E3
    D2 --> E1
    D3 --> E1
    C1 --> E2
    C2 --> E2

    %% Styling
    classDef tier1Style fill:#e1f5ff,stroke:#0077cc,stroke-width:3px,color:#000
    classDef tier2Style fill:#fff4e1,stroke:#ff9900,stroke-width:3px,color:#000
    classDef tier3Style fill:#e1ffe1,stroke:#00aa00,stroke-width:3px,color:#000
    classDef tier4Style fill:#ffe1f5,stroke:#cc0077,stroke-width:3px,color:#000
    classDef externalStyle fill:#f0f0f0,stroke:#666,stroke-width:2px,color:#000

    class A1,A2,A3,A4 tier1Style
    class B1,B2 tier2Style
    class C1,C2,C3 tier3Style
    class D1,D2,D3 tier4Style
    class E1,E2,E3 externalStyle

%% Legend
%% Blue = Tier 1 (Platform Foundations) - BLOCKS ALL
%% Orange = Tier 2 (Detection Capabilities) - BLOCKS features
%% Green = Tier 3 (Plugin Features) - Can parallelize
%% Pink = Tier 4 (Integration) - Final coordination
%% Gray = External dependencies
