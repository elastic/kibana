  "compilerOptions": {
    "outDir": "target/types",
    "types": [
      "jest",
      "node",
      "@kbn/ambient-ui-types"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "target/**/*"
  ],
  "kbn_references": [
    "@kbn/i18n",
    "@kbn/core-ui-settings-browser",
    "@kbn/kibana-react-plugin",
    "@kbn/response-ops-alerts-table"
  ]
}
