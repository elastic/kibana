{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
    "types": [
      "jest",
      "node",
      "react"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "target/**/*"
  ],
  "kbn_references": [
    "@kbn/kibana-react-plugin",
    "@kbn/actions-plugin",
    "@kbn/react-query",
    "@kbn/i18n",
    "@kbn/core-http-browser"
  ]
}
