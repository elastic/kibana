{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
    "types": [
      "jest",
      "node"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "target/**/*"
  ],
  "kbn_references": [
    "@kbn/core-http-browser",
    "@kbn/core-notifications-browser",
    "@kbn/alerting-v2-schemas",
    "@kbn/react-query",
    "@kbn/i18n",
    "@kbn/es-query",
    "@kbn/utility-types",
    "@kbn/deeplinks-alerting-v2"
  ]
}
