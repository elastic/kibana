{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
    "types": [
      "jest",
      "node",
      "react",
      "@kbn/ambient-ui-types"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "target/**/*"
  ],
  "kbn_references": [
    "@kbn/i18n",
    "@kbn/react-query",
    "@kbn/core-http-browser",
    "@kbn/core-notifications-browser",
    "@kbn/core-ui-settings-browser",
    "@kbn/connector-schemas",
    "@kbn/inference-common",
    "@kbn/alerts-ui-shared"
  ]
}
