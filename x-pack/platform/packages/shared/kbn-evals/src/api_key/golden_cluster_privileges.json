{
  "kibana_role_descriptors": {
    "kbn-evals-all": {
      "elasticsearch": {
        "cluster": ["manage_index_templates"],
        "indices": [
          {
            "names": ["kibana-evaluations*"],
            "privileges": [
              "auto_configure",
              "create_index",
              "create_doc",
              "read",
              "view_index_metadata"
            ]
          },
          {
            "names": ["traces-*"],
            "privileges": [
              "auto_configure",
              "create_index",
              "create_doc",
              "read",
              "view_index_metadata"
            ]
          },
          {
            "names": ["kibana-evaluation-dataset*"],
            "privileges": [
              "auto_configure",
              "create_index",
              "create_doc",
              "read",
              "view_index_metadata",
              "delete",
              "index"
            ]
          }
        ]
      },
      "kibana": [
        {
          "base": [],
          "spaces": ["*"],
          "feature": {
            "evals": ["all"]
          }
        }
      ]
    }
  },
  "metadata": {
    "application": "kbn-evals",
    "purpose": "local development"
  }
}
