{
  "type": "plugin",
  "id": "@kbn/data-source-management-plugin",
  "owner": [
    "@elastic/kibana-management"
  ],
  "group": "platform",
  "visibility": "private",
  "description": "Data sets and connectors (data sources) in Stack Management",
  "plugin": {
    "id": "data_source_management",
