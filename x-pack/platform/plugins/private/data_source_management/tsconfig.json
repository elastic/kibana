{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
  },
  "include": [
    "common/**/*",
    "public/**/*",
    "server/**/*",
    "../../../../../typings/**/*"
  ],
  "kbn_references": [
    "@kbn/config-schema",
    "@kbn/core",
    "@kbn/kibana-react-plugin",
