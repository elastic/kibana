{
  "job_id": "auth_high_count_logon_fails_ea",
  "indices": [
    "INDEX_PATTERN_NAME"
  ],
  "max_empty_searches": 10,
  "query": {
    "bool": {
      "filter": [
        {
          "term": {
            "event.category": "authentication"
          }
        },
        {
          "term": {
            "event.outcome": "failure"
          }
        }
      ],
      "must_not": {
        "terms": {
          "process.name": [
            "elastic-agent.exe",
            "elastic-agent",
            "metricbeat.exe",
            "metricbeat",
            "filebeat.exe",
            "filebeat",
            "packetbeat.exe",
            "packetbeat",
            "winlogbeat.exe",
            "winlogbeat"
          ]
        }
      }
    }
  }
}
