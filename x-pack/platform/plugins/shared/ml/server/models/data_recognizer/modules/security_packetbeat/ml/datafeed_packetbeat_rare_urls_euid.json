{
  "job_id": "packetbeat_rare_urls_euid",
  "indices": [
    "INDEX_PATTERN_NAME"
  ],
  "max_empty_searches": 10,
  "query": {
    "bool": {
      "filter": [
        {
          "term": {
            "agent.type": "packetbeat"
          }
        },
        {
          "exists": {
            "field": "url.full"
          }
        }
      ],
      "must_not": [
        {
          "bool": {
            "filter": {
              "term": {
                "destination.ip": "169.254.169.254"
              }
            }
          }
        },
        {
          "terms": {
            "process.name": [
              "elastic-agent.exe",
              "elastic-agent",
              "metricbeat.exe",
              "metricbeat",
              "filebeat.exe",
              "filebeat",
              "packetbeat.exe",
              "packetbeat",
              "winlogbeat.exe",
              "winlogbeat"
            ]
          }
        }
      ]
    }
  },
  "script_fields": {
    "host.entity.id_computed": {
      "script": {
        "id": "euid_host_entity"
      }
    }
  }
}
