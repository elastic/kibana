{
  "job_id": "v3_windows_rare_metadata_process_euid",
  "indices": [
    "INDEX_PATTERN_NAME"
  ],
  "max_empty_searches": 10,
  "query": {
    "bool": {
      "filter": [
        {
          "term": {
            "host.os.family": "windows"
          }
        },
        {
          "term": {
            "destination.ip": "169.254.169.254"
          }
        }
      ],
      "must_not": {
        "terms": {
          "process.name": [
            "elastic-agent.exe",
            "elastic-agent",
            "metricbeat.exe",
            "metricbeat",
            "filebeat.exe",
            "filebeat",
            "packetbeat.exe",
            "packetbeat",
            "winlogbeat.exe",
            "winlogbeat"
          ]
        }
      }
    }
  },
  "script_fields": {
    "user.entity.id_computed": {
      "script": {
        "id": "euid_user_entity"
      }
    },
    "host.entity.id_computed": {
      "script": {
        "id": "euid_host_entity"
      }
    }
  }
}
