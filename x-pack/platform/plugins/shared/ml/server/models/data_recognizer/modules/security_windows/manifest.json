{
  "id": "security_windows_v3",
  "title": "Security: Windows",
  "description": "Anomaly detection jobs for Windows host-based threat hunting and detection.",
  "type": "windows data",
  "logoFile": "logo.json",
  "defaultIndexPattern": "winlogbeat-*,logs-*",
  "query": {
    "bool": {
      "must": [
        {
          "bool": {
            "should": [
              {
                "match": {
                  "host.os.family": {
                    "query": "windows",
                    "operator": "OR"
                  }
                }
              },
              {
                "match": {
                  "host.os.type": {
                    "query": "windows",
                    "operator": "OR"
                  }
                }
              }
            ]
          }
        }
      ],
      "must_not": {
        "terms": {
          "_tier": [
            "data_frozen",
            "data_cold"
          ]
        }
      }
    }
  },
