{
  "description": "Security: Linux - Looks for sudo activity from an unusual unique user identifier context. Unusual unique user identifier context changes can be due to privilege escalation.",
  "groups": [
    "security",
    "linux"
  ],
  "analysis_config": {
    "bucket_span": "15m",
    "detectors": [
      {
        "detector_description": "Detects rare usernames.",
        "function": "rare",
        "by_field_name": "user.entity.id_computed",
        "detector_index": 0
      }
    ],
    "influencers": [
      "process.name",
      "host.entity.id_computed",
      "host.name",
      "process.args",
      "user.entity.id_computed",
      "user.name"
    ]
  },
  "allow_lazy_open": true,
  "analysis_limits": {
    "model_memory_limit": "32mb"
  },
  "data_description": {
    "time_field": "@timestamp"
  },
  "custom_settings": {
    "created_by": "ml-module-security-linux-v3",
    "security_app_display_name": "Unusual Sudo Activity",
    "managed": true,
    "job_revision": 4
  }
}
