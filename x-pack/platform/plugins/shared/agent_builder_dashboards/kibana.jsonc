{
  "type": "plugin",
  "id": "@kbn/agent-builder-dashboards-plugin",
  "owner": "@elastic/appex-ai-infra",
  "group": "platform",
  "visibility": "shared",
  "plugin": {
    "id": "agentBuilderDashboards",
    "server": true,
    "browser": true,
    "configPath": ["xpack", "agentBuilderDashboards"],
    "requiredPlugins": [
      "agentBuilder",
      "dashboard",
      "dashboardMarkdown",
      "data",
      "agentContextLayer",
      "embeddable",
      "share",
      "unifiedSearch"
    ]
  }
}
