{
  "type": "plugin",
  "id": "@kbn/inference-workflows-plugin",
  "owner": ["@elastic/workchat-eng"],
  "group": "platform",
  "visibility": "shared",
  "description": "AI steps, PII steps, and inference lifecycle hooks for the Workflows framework.",
  "plugin": {
    "id": "inferenceWorkflows",
    "server": true,
    "browser": true,
    "configPath": ["xpack", "inferenceWorkflows"],
    "requiredPlugins": ["inference", "workflowsExtensions"]
  }
}
