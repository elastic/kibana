{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types"
  },
  "include": [
    "common/**/*",
    "public/**/*",
    "server/**/*",
    "test/scout/**/*"
  ],
  "exclude": [
    "target/**/*"
  ],
  "kbn_references": [
    "@kbn/core",
    "@kbn/config-schema",
    "@kbn/i18n",
    "@kbn/shared-ux-utility",
    "@kbn/shared-ux-router",
    "@kbn/spaces-plugin",
    "@kbn/cloud-plugin",
    "@kbn/deeplinks-observability",
    "@kbn/scout",
    "@kbn/kibana-react-plugin",
    "@kbn/react-query",
    "@kbn/fleet-plugin",
    "@kbn/i18n-react"
  ]
}
