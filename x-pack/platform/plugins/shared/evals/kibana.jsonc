{
  "type": "plugin",
  "id": "@kbn/evals-plugin",
  "owner": ["@elastic/obs-ai-team", "@elastic/security-genai-research-and-development"],
  "group": "platform",
  "visibility": "shared",
  "plugin": {
    "id": "evals",
    "server": true,
    "browser": true,
    "configPath": ["xpack", "evals"],
    "requiredPlugins": ["features", "encryptedSavedObjects"],
    "optionalPlugins": ["management"],
    "requiredBundles": ["kibanaReact"]
  }
}
