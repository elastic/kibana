{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
    "types": ["node"],
    "isolatedModules": false,
    "composite": true
  },
  "include": [
    "./scout_agent_builder_api/**/*",
    "./scout_agent_builder_smoke/**/*",
    "./scout_agent_builder_functional/**/*",
    "./scout_agent_builder_shared/**/*",
    "../server/**/*.ts",
    "../common/**/*.ts",
    "../../../../test/agent_builder_api_integration/utils/plugins_server/plugins_server.ts"
  ],
  "exclude": ["target/**/*"],
  "kbn_references": [
    "@kbn/scout",
    "@kbn/scout-synthtrace",
    "@kbn/synthtrace-client",
    "@kbn/ftr-llm-proxy",
    "@kbn/kbn-client",
    "@kbn/tooling-log",
    "@kbn/test-subj-selector",
    "@kbn/agent-builder-common",
    "@kbn/agent-builder-plugin",
    "@kbn/gen-ai-functional-testing",
    "@kbn/agent-builder-server",
    "@kbn/repo-info",
    "@kbn/test-suites-xpack-platform"
  ]
}
