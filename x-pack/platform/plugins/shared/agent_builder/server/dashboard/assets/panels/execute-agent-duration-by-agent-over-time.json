{
  "type": "vis",
  "embeddableConfig": {
    "attributes": {
      "visualizationType": "lnsXY",
      "title": "ExecuteAgent Avg Duration by Agent Over Time",
      "state": {
        "datasourceStates": {
          "textBased": {
            "layers": {
              "line_0": {
                "index": "traces-agent_builder.otel-default-@timestamp",
                "query": {
                  "esql": "FROM traces-agent_builder.otel-default\n| WHERE @timestamp >= ?_tstart AND @timestamp < ?_tend AND data_stream.dataset == \"agent_builder.otel\"\n| WHERE name == \"ExecuteAgent\"\n| EVAL duration_sec = duration / 1000000000.0\n| STATS `Avg Duration (s)` = ROUND(AVG(duration_sec), 2) BY `Time` = BUCKET(@timestamp, 75, ?_tstart, ?_tend), `Agent` = attributes.elastic.agent.id\n| SORT `Time`"
                },
