{
  "definition_version": 1,
  "title": "[Agent Builder] Overview Dashboard",
  "description": "Comprehensive monitoring dashboard for Agent Builder OTel traces (data_stream.dataset: agent_builder) including token usage, cost, conversation volume, agent execution, tool calls, workflows, and LLM requests.",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "options": {
    "auto_apply_filters": true,
    "hide_panel_titles": false,
    "use_margins": true,
    "sync_cursor": true
  },
  "sections": [
    {
      "id": "token-usage-cost",
      "title": "Token Usage & Cost",
      "panels": [
        {
          "$ref": "panels/chatcomplete-token-usage-over-time.json",
          "grid": {
            "x": 0,
            "y": 0,
            "w": 48,
            "h": 12
          }
        },
        {
          "$ref": "panels/chatcomplete-total-input-tokens-metric.json",
          "grid": {
            "x": 0,
            "y": 12,
            "w": 12,
            "h": 5
          }
        },
        {
          "$ref": "panels/chatcomplete-total-output-tokens-metric.json",
          "grid": {
            "x": 12,
            "y": 12,
            "w": 12,
            "h": 5
          }
        },
        {
          "$ref": "panels/chatcomplete-total-cost-metric.json",
