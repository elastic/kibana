            "x": 0,
            "y": 27,
            "w": 24,
            "h": 10
          }
        },
        {
          "$ref": "panels/chatcomplete-latency-by-provider-over-time.json",
          "grid": {
            "x": 24,
            "y": 27,
            "w": 24,
            "h": 10
          }
        },
        {
          "$ref": "panels/chatcomplete-count-by-model-bar.json",
          "grid": {
            "x": 0,
            "y": 37,
            "w": 24,
            "h": 10
          }
