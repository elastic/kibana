{
  "type": "vis",
  "embeddableConfig": {
    "attributes": {
      "visualizationType": "lnsXY",
      "title": "Total Token Usage Over Time by Model",
      "state": {
        "datasourceStates": {
          "textBased": {
            "layers": {
              "area_stacked_0": {
                "index": "traces-agent_builder.otel-default-@timestamp",
                "query": {
                  "esql": "FROM traces-agent_builder.otel-default\n| WHERE @timestamp >= ?_tstart AND @timestamp < ?_tend AND data_stream.dataset == \"agent_builder\"\n| WHERE name == \"ChatComplete\"\n| STATS `Total Tokens` = SUM(TO_LONG(attributes.gen_ai.usage.input_tokens)) + SUM(TO_LONG(attributes.gen_ai.usage.output_tokens)) BY `Time` = BUCKET(@timestamp, 75, ?_tstart, ?_tend), `Model` = attributes.gen_ai.request.model"
                },
                "timeField": "@timestamp",
                "columns": [
                  {
                    "columnId": "area_stacked_x",
                    "fieldName": "Time",
                    "meta": {
                      "type": "string"
                    }
                  },
                  {
                    "columnId": "area_stacked_y_0",
                    "fieldName": "Total Tokens",
                    "meta": {
                      "type": "number"
                    }
                  },
                  {
                    "columnId": "area_stacked_breakdown",
                    "fieldName": "Model",
                    "meta": {
                      "type": "string"
                    }
                  }
                ],
                "ignoreGlobalFilters": false
