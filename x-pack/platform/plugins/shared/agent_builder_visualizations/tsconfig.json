  "compilerOptions": {
    "outDir": "target/types"
  },
  "include": ["common/**/*", "public/**/*", "server/**/*"],
  "kbn_references": [
    "@kbn/core",
    "@kbn/agent-builder-server",
    "@kbn/agent-builder-browser",
    "@kbn/agent-builder-visualizations",
    "@kbn/agent-builder-visualizations-common",
