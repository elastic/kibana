{
  "type": "plugin",
  "id": "@kbn/elastic-console-plugin",
  "owner": "@elastic/obs-onboarding-team",
  "group": "platform",
  "visibility": "shared",
  "plugin": {
    "id": "elasticConsole",
    "server": true,
    "browser": true,
    "configPath": ["xpack", "elasticConsole"],
    "requiredPlugins": ["inference", "actions"],
    "requiredBundles": ["kibanaReact"],
    "optionalPlugins": ["cloud"]
  }
}
