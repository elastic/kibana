{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types"
  },
  "include": [
    "common/**/*",
    "public/**/*",
    "server/**/*",
    "../../../../../typings/**/*"
  ],
  "exclude": [
    "target/**/*"
  ],
  "kbn_references": [
    "@kbn/core",
    "@kbn/config-schema",
    "@kbn/i18n",
    "@kbn/i18n-react",
    "@kbn/management-plugin",
    "@kbn/features-plugin",
    "@kbn/encrypted-saved-objects-plugin"
  ]
}
