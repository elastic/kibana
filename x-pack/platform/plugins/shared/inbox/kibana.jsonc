{
  "type": "plugin",
  "id": "@kbn/inbox-plugin",
  "owner": ["@elastic/security-pds-deployment"],
  "group": "platform",
  "visibility": "shared",
  "plugin": {
    "id": "inbox",
    "server": true,
    "browser": true,
    "configPath": ["xpack", "inbox"],
