{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types"
  },
  "include": [
    "index.ts",
    "common/**/*.ts",
    "public/**/*.ts",
    "public/**/*.tsx",
    "server/**/*.ts",
    "../../../../../typings/**/*",
  ],
  "exclude": [
    "target/**/*"
  ],
  "kbn_references": [
    "@kbn/core",
    "@kbn/serverless",
    "@kbn/config-schema",
    "@kbn/core-security-server",
    "@kbn/serverless-vectordb-settings",
    "@kbn/i18n-react",
    "@kbn/kibana-react-plugin",
    "@kbn/share-plugin",
    "@kbn/console-plugin",
    "@kbn/core-chrome-browser",
    "@kbn/cloud-plugin",
    "@kbn/shared-components",
    "@kbn/shared-ux-router",
    "@kbn/agent-builder-plugin",
    "@kbn/vectordb-onboarding",
    "@kbn/react-query",
    "@kbn/i18n",
    "@kbn/core-application-browser",
    "@kbn/deeplinks-management",
    "@kbn/ai-assistant-common",
    "@kbn/management-settings-ids",
    "@kbn/data-views-plugin",
  ]
}
