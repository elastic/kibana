graph TB
    subgraph "Input Layer"
        LOGS[Log Sources]
        ALERTS[Security Alerts]
        CSV["CSV / API Input"]
    end

    subgraph "Entity Store (v1 indices)"
        direction TB
        EXTRACT[ESQL Extraction Task]
        UPDATES["Updates Data Stream<br/>(.entities.v1.updates.*)"]
        PIVOT[Pivot Transform]
        LATEST_E["Latest Entity Index<br/>(.entities.v1.latest.*)"]
        ENRICH[Field Retention Enrich]
        SNAP[Snapshot Task]
        HISTORY["History Index<br/>(.entities.v1.history.*)"]
    end

    subgraph "Asset Criticality"
        AC_INDEX[Criticality Index]
        AC_SVC[Criticality Service]
    end

    subgraph "Risk Engine"
        direction TB
        TASK[Risk Scoring Task]
        ESQL[ESQL Aggregation]
        MODS[Score Modifiers]
        RS_DS[Risk Score Data Stream]
        RS_TX[Latest Transform]
        RS_LATEST[Risk Score Latest Index]
    end

    subgraph "Privilege Monitoring"
        PM_ENGINE[Monitoring Engine]
        PM_USERS[Privileged Users]
    end

    subgraph "Consumers"
        DASH[Dashboards]
        FLYOUT[Entity Flyouts]
        RULES[Detection Rules]
        ASSIST[AI Assistant]
    end

    LOGS --> EXTRACT
    EXTRACT --> UPDATES
    UPDATES --> PIVOT
    PIVOT --> LATEST_E
    LATEST_E --> ENRICH --> LATEST_E
    LATEST_E --> SNAP --> HISTORY

    CSV --> AC_INDEX
    AC_INDEX --> AC_SVC

    ALERTS --> TASK
    TASK --> ESQL
    ESQL --> MODS
    AC_SVC -->|criticality modifier| MODS
    PM_USERS -->|privmon modifier| MODS
    MODS --> RS_DS
    RS_DS --> RS_TX
    RS_TX --> RS_LATEST

    LATEST_E --> DASH
    RS_LATEST --> DASH
    LATEST_E --> FLYOUT
    RS_LATEST --> FLYOUT
    RS_LATEST --> RULES
    RS_LATEST --> ASSIST
