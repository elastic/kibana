{
  "plugins": ["cypress"],
  "extends": [
    "plugin:cypress/recommended"
  ],
  "env": {
    "cypress/globals": true
  },
  "rules": {
    "cypress/no-force": "warn",
    "import/no-extraneous-dependencies": "off"
  },
  "overrides": [
    {
      "files": ["scripts/**/*.js"],
      "rules": {
        "import/no-nodejs-modules": "off"
      }
    }
  ]
}
