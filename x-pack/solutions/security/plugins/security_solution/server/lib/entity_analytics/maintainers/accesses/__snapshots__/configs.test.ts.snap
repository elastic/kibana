 entity.namespace = CASE((NOT(\`user.name\` IS NULL) AND COALESCE(\`user.name\` != \\"\\", TRUE) AND NOT(\`host.id\` IS NULL) AND COALESCE(\`host.id\` != \\"\\", TRUE) AND NOT (COALESCE(\`user.name\` == \\"root\\", FALSE) OR COALESCE(\`user.name\` == \\"bin\\", FALSE) OR COALESCE(\`user.name\` == \\"daemon\\", FALSE) OR COALESCE(\`user.name\` == \\"sys\\", FALSE) OR COALESCE(\`user.name\` == \\"nobody\\", FALSE) OR COALESCE(\`user.name\` == \\"jenkins\\", FALSE) OR COALESCE(\`user.name\` == \\"ansible\\", FALSE) OR COALESCE(\`user.name\` == \\"deploy\\", FALSE) OR COALESCE(\`user.name\` == \\"terraform\\", FALSE) OR COALESCE(\`user.name\` == \\"gitlab-runner\\", FALSE) OR COALESCE(\`user.name\` == \\"postgres\\", FALSE) OR COALESCE(\`user.name\` == \\"mysql\\", FALSE) OR COALESCE(\`user.name\` == \\"redis\\", FALSE) OR COALESCE(\`user.name\` == \\"elasticsearch\\", FALSE) OR COALESCE(\`user.name\` == \\"kafka\\", FALSE) OR COALESCE(\`user.name\` == \\"admin\\", FALSE) OR COALESCE(\`user.name\` == \\"operator\\", FALSE) OR COALESCE(\`user.name\` == \\"service\\", FALSE)) AND (COALESCE(MV_CONTAINS(\`event.kind\`, \\"asset\\"), FALSE) OR NOT (COALESCE(MV_CONTAINS(\`event.kind\`, \\"asset\\"), FALSE) OR (COALESCE(\`event.kind\` != \\"enrichment\\", TRUE) OR \`event.kind\` IS NULL) AND COALESCE(MV_CONTAINS(\`event.category\`, \\"iam\\"), FALSE) AND (COALESCE(MV_CONTAINS(\`event.type\`, \\"user\\"), FALSE) OR COALESCE(MV_CONTAINS(\`event.type\`, \\"creation\\"), FALSE) OR COALESCE(MV_CONTAINS(\`event.type\`, \\"deletion\\"), FALSE) OR COALESCE(MV_CONTAINS(\`event.type\`, \\"group\\"), FALSE))))), \\"local\\", (_src_entity_namespace == \\"okta\\" OR _src_entity_namespace == \\"entityanalytics_okta\\"), \\"okta\\", (_src_entity_namespace == \\"azure\\" OR _src_entity_namespace == \\"entityanalytics_entra_id\\"), \\"entra_id\\", (_src_entity_namespace == \\"o365\\" OR _src_entity_namespace == \\"o365_metrics\\"), \\"microsoft_365\\", (_src_entity_namespace == \\"entityanalytics_ad\\"), \\"active_directory\\", (_src_entity_namespace IS NULL OR _src_entity_namespace == \\"\\"), \\"unknown\\", _src_entity_namespace)
| EVAL actorUserId = CONCAT(\\"user:\\", CASE((COALESCE(\`entity.namespace\` == \\"local\\", FALSE)), CASE((user.name IS NOT NULL AND user.name != \\"\\" AND host.id IS NOT NULL AND host.id != \\"\\" AND entity.namespace IS NOT NULL AND entity.namespace != \\"\\"), CONCAT(user.name, \\"@\\", host.id, \\"@\\", entity.namespace), NULL),
true, CASE((user.email IS NOT NULL AND user.email != \\"\\" AND entity.namespace IS NOT NULL AND entity.namespace != \\"\\"), CONCAT(user.email, \\"@\\", entity.namespace),
(user.id IS NOT NULL AND user.id != \\"\\" AND entity.namespace IS NOT NULL AND entity.namespace != \\"\\"), CONCAT(user.id, \\"@\\", entity.namespace),
(user.name IS NOT NULL AND user.name != \\"\\" AND user.domain IS NOT NULL AND user.domain != \\"\\" AND entity.namespace IS NOT NULL AND entity.namespace != \\"\\"), CONCAT(user.name, \\"@\\", user.domain, \\"@\\", entity.namespace),
(user.name IS NOT NULL AND user.name != \\"\\" AND entity.namespace IS NOT NULL AND entity.namespace != \\"\\"), CONCAT(user.name, \\"@\\", entity.namespace), NULL), NULL))
| WHERE COALESCE(actorUserId, \\"\\") != \\"\\"
| EVAL targetEntityId = CONCAT(\\"host:\\", CASE((host.id IS NOT NULL AND host.id != \\"\\"), host.id,
(host.name IS NOT NULL AND host.name != \\"\\"), host.name,
(host.hostname IS NOT NULL AND host.hostname != \\"\\"), host.hostname, NULL))
| MV_EXPAND targetEntityId
| WHERE COALESCE(targetEntityId, \\"\\") != \\"\\"
| STATS access_count = COUNT(*) BY actorUserId, targetEntityId
| EVAL access_type = CASE(
    access_count >= 4, \\"accesses_frequently\\",
    \\"accesses_infrequently\\"
  )
| STATS targets = VALUES(targetEntityId) BY access_type, actorUserId
| STATS
    accesses_frequently = VALUES(targets) WHERE access_type == \\"accesses_frequently\\",
    accesses_infrequently = VALUES(targets) WHERE access_type == \\"accesses_infrequently\\"
  BY actorUserId
| LIMIT 3500"
`;
