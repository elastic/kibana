exports[`parseRulePreviewCommand — snapshots: help output machine_learning --help 1`] = `
Object {
  "kind": "help",
  "text": "  machine_learning

Machine learning anomaly detection rule

Options:
  --interval           Rule run frequency, e.g. \\"5m\\", \\"1h\\"  [string] [default: \\"1h\\"]
  --timeframe-start    Preview window start as datemath, e.g. \\"now-24h\\"  [string] [default: \\"now-1h\\"]
  --timeframe-end      Preview window end as datemath  [string] [default: \\"now\\"]
  --job-id             ML job ID (repeat for multiple jobs)  [array] [required]
  --anomaly-threshold  Minimum anomaly score to alert (0–100)  [number] [required]
  -h, --help           Show help  [boolean]

Examples:
   machine_learning --job-id my-ml-job --anomaly-threshold 75
   machine_learning --job-id job-a --job-id job-b --anomaly-threshold 50",
}
`;

exports[`parseRulePreviewCommand — snapshots: help output new_terms --help 1`] = `
Object {
  "kind": "help",
  "text": "  new_terms

New terms detection rule

Options:
  --interval              Rule run frequency, e.g. \\"5m\\", \\"1h\\"  [string] [default: \\"1h\\"]
  --timeframe-start       Preview window start as datemath, e.g. \\"now-24h\\"  [string] [default: \\"now-1h\\"]
  --timeframe-end         Preview window end as datemath  [string] [default: \\"now\\"]
  --query                 KQL / Lucene query for events to analyse  [string] [required]
  --new-terms-fields      Field(s) to monitor for new values (repeat for multiple, max 3)  [array] [required]
  --history-window-start  Start of the baseline window as datemath, e.g. \\"now-30d\\"  [string] [required]
  --language              Query language: \\"kuery\\" (KQL, default) or \\"lucene\\"  [string] [choices: \\"kuery\\", \\"lucene\\"] [default: \\"kuery\\"]
  --index                 Index pattern (repeat for multiple)  [array]
  --data-view-id          Kibana data view ID (alternative to --index)  [string]
  -h, --help              Show help  [boolean]

Examples:
   new_terms --query \\"*:*\\" --new-terms-fields source.ip --history-window-start now-30d",
}
`;

exports[`parseRulePreviewCommand — snapshots: help output query --help 1`] = `
Object {
  "kind": "help",
  "text": "  query

Custom query detection rule (KQL / Lucene)

Options:
  --interval         Rule run frequency, e.g. \\"5m\\", \\"1h\\"  [string] [default: \\"1h\\"]
  --timeframe-start  Preview window start as datemath, e.g. \\"now-24h\\"  [string] [default: \\"now-1h\\"]
  --timeframe-end    Preview window end as datemath  [string] [default: \\"now\\"]
  --query            KQL / Lucene query (omit to match all documents)  [string]
  --language         Query language: \\"kuery\\" (KQL, default) or \\"lucene\\"  [string] [choices: \\"kuery\\", \\"lucene\\"] [default: \\"kuery\\"]
  --index            Index pattern (repeat for multiple)  [array]
  --data-view-id     Kibana data view ID (alternative to --index)  [string]
  -h, --help         Show help  [boolean]

Examples:
   query --query \\"event.category:authentication AND event.outcome:failure\\"",
}
`;

