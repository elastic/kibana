exports[`parseRulePreviewCommand — snapshots: help output threat_match --help 1`] = `
Object {
  "kind": "help",
  "text": "  threat_match

Threat indicator match detection rule

Options:
  --interval               Rule run frequency, e.g. \\"5m\\", \\"1h\\"  [string] [default: \\"1h\\"]
  --timeframe-start        Preview window start as datemath, e.g. \\"now-24h\\"  [string] [default: \\"now-1h\\"]
  --timeframe-end          Preview window end as datemath  [string] [default: \\"now\\"]
  --query                  Source events query  [string] [required]
  --threat-query           Query against the threat index  [string] [required]
  --threat-index           Threat intelligence index pattern (repeat for multiple)  [array] [required]
  --threat-mapping         JSON array of field-mapping entries: '[{\\"entries\\":[{\\"field\\":\\"src.ip\\",\\"type\\":\\"mapping\\",\\"value\\":\\"dst.ip\\"}]}]'  [string] [required]
  --threat-filters         Additional threat index filters (JSON array)  [string]
  --threat-indicator-path  Nested path to indicator object (default: \\"threat.indicator\\")  [string]
  --language               Query language: \\"kuery\\" (KQL, default) or \\"lucene\\"  [string] [choices: \\"kuery\\", \\"lucene\\"] [default: \\"kuery\\"]
  --index                  Index pattern (repeat for multiple)  [array]
  --data-view-id           Kibana data view ID (alternative to --index)  [string]
  -h, --help               Show help  [boolean]

Examples:
   threat_match --query \\"*:*\\" --threat-query \\"*:*\\" --threat-index logs-ti_* --threat-mapping '[{\\"entries\\":[{\\"field\\":\\"source.ip\\",\\"type\\":\\"mapping\\",\\"value\\":\\"threat.indicator.ip\\"}]}]'",
}
`;

exports[`parseRulePreviewCommand — snapshots: help output threshold --help 1`] = `
Object {
  "kind": "help",
  "text": "  threshold

Threshold-based detection rule

Options:
  --interval         Rule run frequency, e.g. \\"5m\\", \\"1h\\"  [string] [default: \\"1h\\"]
  --timeframe-start  Preview window start as datemath, e.g. \\"now-24h\\"  [string] [default: \\"now-1h\\"]
  --timeframe-end    Preview window end as datemath  [string] [default: \\"now\\"]
  --query            KQL / Lucene query  [string] [required]
  --threshold-value  Minimum event count to alert (integer ≥ 1)  [number] [required]
  --threshold-field  Group-by field(s) (repeat for multiple, omit for no grouping)  [array]
  --language         Query language: \\"kuery\\" (KQL, default) or \\"lucene\\"  [string] [choices: \\"kuery\\", \\"lucene\\"] [default: \\"kuery\\"]
  --index            Index pattern (repeat for multiple)  [array]
  --data-view-id     Kibana data view ID (alternative to --index)  [string]
  -h, --help         Show help  [boolean]

Examples:
   threshold --query \\"event.category:auth\\" --threshold-value 10 --threshold-field host.name",
}
`;
