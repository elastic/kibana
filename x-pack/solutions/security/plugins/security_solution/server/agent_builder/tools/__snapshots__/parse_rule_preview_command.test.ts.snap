exports[`parseRulePreviewCommand — snapshots: help output -h shorthand 1`] = `
Object {
  "kind": "help",
  "text": "  <command>

Commands:
   esql             ES|QL detection rule
   eql              EQL (event query language) detection rule
   query            Custom query detection rule (KQL / Lucene)
   saved_query      Saved query detection rule
   threshold        Threshold-based detection rule
   threat_match     Threat indicator match detection rule
   machine_learning  Machine learning anomaly detection rule
   new_terms        New terms detection rule

Options:
  --interval         Rule run frequency, e.g. \\"5m\\", \\"1h\\"  [string] [default: \\"1h\\"]
  --timeframe-start  Preview window start as datemath, e.g. \\"now-24h\\"  [string] [default: \\"now-1h\\"]
  --timeframe-end    Preview window end as datemath  [string] [default: \\"now\\"]
  -h, --help         Show help  [boolean]",
}
`;

exports[`parseRulePreviewCommand — snapshots: help output eql --help 1`] = `
Object {
  "kind": "help",
  "text": "  eql

EQL (event query language) detection rule

Options:
  --interval         Rule run frequency, e.g. \\"5m\\", \\"1h\\"  [string] [default: \\"1h\\"]
  --timeframe-start  Preview window start as datemath, e.g. \\"now-24h\\"  [string] [default: \\"now-1h\\"]
  --timeframe-end    Preview window end as datemath  [string] [default: \\"now\\"]
  --query            EQL query string  [string] [required]
  --index            Index pattern (repeat for multiple)  [array]
  --data-view-id     Kibana data view ID (alternative to --index)  [string]
  -h, --help         Show help  [boolean]

Examples:
   eql --query \\"process where process.name == \\\\\\"cmd.exe\\\\\\"\\"",
}
`;

