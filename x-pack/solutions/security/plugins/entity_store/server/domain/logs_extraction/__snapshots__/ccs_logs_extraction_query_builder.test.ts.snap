 cloud.service.name = LAST(TO_STRING(cloud.service.name), @timestamp) WHERE cloud.service.name IS NOT NULL,
 orchestrator.api_version = LAST(TO_STRING(orchestrator.api_version), @timestamp) WHERE orchestrator.api_version IS NOT NULL,
 orchestrator.cluster.id = LAST(TO_STRING(orchestrator.cluster.id), @timestamp) WHERE orchestrator.cluster.id IS NOT NULL,
 orchestrator.cluster.name = LAST(TO_STRING(orchestrator.cluster.name), @timestamp) WHERE orchestrator.cluster.name IS NOT NULL,
 orchestrator.cluster.url = LAST(TO_STRING(orchestrator.cluster.url), @timestamp) WHERE orchestrator.cluster.url IS NOT NULL,
 orchestrator.cluster.version = LAST(TO_STRING(orchestrator.cluster.version), @timestamp) WHERE orchestrator.cluster.version IS NOT NULL,
 orchestrator.namespace = LAST(TO_STRING(orchestrator.namespace), @timestamp) WHERE orchestrator.namespace IS NOT NULL,
 orchestrator.organization = LAST(TO_STRING(orchestrator.organization), @timestamp) WHERE orchestrator.organization IS NOT NULL,
 orchestrator.resource.annotation = LAST(TO_STRING(orchestrator.resource.annotation), @timestamp) WHERE orchestrator.resource.annotation IS NOT NULL,
 orchestrator.resource.id = LAST(TO_STRING(orchestrator.resource.id), @timestamp) WHERE orchestrator.resource.id IS NOT NULL,
 orchestrator.resource.ip = LAST(TO_IP(orchestrator.resource.ip), @timestamp) WHERE orchestrator.resource.ip IS NOT NULL,
 orchestrator.resource.label = LAST(TO_STRING(orchestrator.resource.label), @timestamp) WHERE orchestrator.resource.label IS NOT NULL,
