 entity.relationships.resolution.risk.calculated_score_norm = LAST(TO_DOUBLE(user.entity.relationships.resolution.risk.calculated_score_norm), @timestamp) WHERE TO_DOUBLE(user.entity.relationships.resolution.risk.calculated_score_norm) IS NOT NULL,
