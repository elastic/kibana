 host.id = VALUES(TO_STRING(host.id)),
 host.name = LAST(TO_STRING(host.name), @timestamp) WHERE TO_STRING(host.name) IS NOT NULL
    BY entity.id
| EVAL entity.name = CASE((TO_STRING(entity.namespace) == \\"local\\" AND TO_STRING(host.name) IS NOT NULL AND TO_STRING(host.name) != \\"\\"), CONCAT(TO_STRING(user.name), \\"@\\", TO_STRING(host.name)), entity.name),
    entity.name = CASE((TO_STRING(entity.namespace) == \\"local\\" AND NOT (TO_STRING(host.name) IS NOT NULL AND TO_STRING(host.name) != \\"\\")), TO_STRING(user.name), entity.name),
    entity.name = CASE((TO_STRING(entity.namespace) != \\"local\\"), TO_STRING(user.name), entity.name),
    entity.confidence = CASE((TO_STRING(entity.namespace) != \\"local\\"), \\"high\\", entity.confidence),
    entity.confidence = CASE((TO_STRING(entity.namespace) == \\"local\\"), \\"medium\\", entity.confidence)
| KEEP entity*,
event*,
user*,
asset*,
data_stream*,
host*,
@timestamp
| SORT entity.EngineMetadata.FirstSeenLogInPage ASC, entity.id ASC
| WHERE entity.EngineMetadata.FirstSeenLogInPage > TO_DATETIME(\\"2022-01-01T12:00:00.000Z\\") 
            OR (entity.EngineMetadata.FirstSeenLogInPage == TO_DATETIME(\\"2022-01-01T12:00:00.000Z\\") 
                AND entity.id > \\"cursor-id\\")
| LIMIT 10000"
`;

exports[`buildCcsLogsExtractionEsqlQuery generates query for generic entity type 1`] = `
"SET unmapped_fields=\\"nullify\\";
FROM remote_cluster:logs-*
  | WHERE
      @timestamp >= TO_DATETIME(\\"2022-01-01T00:00:00.000Z\\")
      AND @timestamp <= TO_DATETIME(\\"2022-01-01T23:59:59.999Z\\")
      AND ((TO_STRING(entity.id) IS NOT NULL AND TO_STRING(entity.id) != \\"\\"))
| EVAL _src_entity_source0 = MV_FIRST(TO_STRING(event.module)),
 _src_entity_source1 = MV_FIRST(TO_STRING(event.dataset)),
 _src_entity_source2 = MV_FIRST(TO_STRING(data_stream.dataset)),
 _src_entity_source = COALESCE(CASE(_src_entity_source0 IS NOT NULL AND _src_entity_source0 != \\"\\", _src_entity_source0), CASE(_src_entity_source1 IS NOT NULL AND _src_entity_source1 != \\"\\", _src_entity_source1), CASE(_src_entity_source2 IS NOT NULL AND _src_entity_source2 != \\"\\", _src_entity_source2)),
 entity.source = CASE(_src_entity_source IS NULL OR _src_entity_source == \\"\\", NULL, _src_entity_source),
 entity.id = TO_STRING(entity.id)
| STATS
    @timestamp = MAX(@timestamp),
    entity.EngineMetadata.FirstSeenLogInPage = MIN(@timestamp),
    entity.id = LAST(TO_STRING(entity.id), @timestamp) WHERE TO_STRING(entity.id) IS NOT NULL,
 entity.name = LAST(TO_STRING(entity.name), @timestamp) WHERE TO_STRING(entity.name) IS NOT NULL,
 event.module = VALUES(TO_STRING(event.module)),
