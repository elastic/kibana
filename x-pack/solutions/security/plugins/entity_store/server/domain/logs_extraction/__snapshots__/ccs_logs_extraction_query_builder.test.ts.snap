 orchestrator.resource.annotation = LAST(TO_STRING(orchestrator.resource.annotation), @timestamp) WHERE TO_STRING(orchestrator.resource.annotation) IS NOT NULL,
 orchestrator.resource.id = LAST(TO_STRING(orchestrator.resource.id), @timestamp) WHERE TO_STRING(orchestrator.resource.id) IS NOT NULL,
 orchestrator.resource.ip = LAST(TO_IP(orchestrator.resource.ip), @timestamp) WHERE TO_IP(orchestrator.resource.ip) IS NOT NULL,
 orchestrator.resource.label = LAST(TO_STRING(orchestrator.resource.label), @timestamp) WHERE TO_STRING(orchestrator.resource.label) IS NOT NULL,
 orchestrator.resource.name = LAST(TO_STRING(orchestrator.resource.name), @timestamp) WHERE TO_STRING(orchestrator.resource.name) IS NOT NULL,
 orchestrator.resource.parent.type = LAST(TO_STRING(orchestrator.resource.parent.type), @timestamp) WHERE TO_STRING(orchestrator.resource.parent.type) IS NOT NULL,
 orchestrator.resource.type = LAST(TO_STRING(orchestrator.resource.type), @timestamp) WHERE TO_STRING(orchestrator.resource.type) IS NOT NULL,
 orchestrator.type = LAST(TO_STRING(orchestrator.type), @timestamp) WHERE TO_STRING(orchestrator.type) IS NOT NULL,
 asset.id = LAST(TO_STRING(asset.id), @timestamp) WHERE TO_STRING(asset.id) IS NOT NULL,
 asset.name = LAST(TO_STRING(asset.name), @timestamp) WHERE TO_STRING(asset.name) IS NOT NULL,
 asset.owner = LAST(TO_STRING(asset.owner), @timestamp) WHERE TO_STRING(asset.owner) IS NOT NULL,
 asset.serial_number = LAST(TO_STRING(asset.serial_number), @timestamp) WHERE TO_STRING(asset.serial_number) IS NOT NULL,
 asset.model = LAST(TO_STRING(asset.model), @timestamp) WHERE TO_STRING(asset.model) IS NOT NULL,
 asset.vendor = LAST(TO_STRING(asset.vendor), @timestamp) WHERE TO_STRING(asset.vendor) IS NOT NULL,
 asset.environment = LAST(TO_STRING(asset.environment), @timestamp) WHERE TO_STRING(asset.environment) IS NOT NULL,
 asset.criticality = LAST(TO_STRING(asset.criticality), @timestamp) WHERE TO_STRING(asset.criticality) IS NOT NULL,
 asset.business_unit = LAST(TO_STRING(asset.business_unit), @timestamp) WHERE TO_STRING(asset.business_unit) IS NOT NULL,
 entity.risk.calculated_level = LAST(TO_STRING(entity.risk.calculated_level), @timestamp) WHERE TO_STRING(entity.risk.calculated_level) IS NOT NULL,
 entity.risk.calculated_score = LAST(TO_DOUBLE(entity.risk.calculated_score), @timestamp) WHERE TO_DOUBLE(entity.risk.calculated_score) IS NOT NULL,
 entity.risk.calculated_score_norm = LAST(TO_DOUBLE(entity.risk.calculated_score_norm), @timestamp) WHERE TO_DOUBLE(entity.risk.calculated_score_norm) IS NOT NULL
    BY entity.id
| KEEP entity*,
event*,
data_stream*,
cloud*,
orchestrator*,
asset*,
@timestamp
| SORT entity.EngineMetadata.FirstSeenLogInPage ASC, entity.id ASC
| LIMIT 10000"
`;
