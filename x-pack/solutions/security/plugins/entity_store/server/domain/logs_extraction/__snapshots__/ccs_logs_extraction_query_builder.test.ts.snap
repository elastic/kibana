 host.name = LAST(TO_STRING(host.name), @timestamp) WHERE TO_STRING(host.name) IS NOT NULL
    BY entity.id
| EVAL entity.name = CASE((COALESCE(\`entity.namespace\` == \\"local\\", FALSE) AND NOT(\`host.name\` IS NULL) AND COALESCE(\`host.name\` != \\"\\", TRUE)), CONCAT(TO_STRING(user.name), \\"@\\", TO_STRING(host.name)), entity.name)
| EVAL entity.name = CASE((COALESCE(\`entity.namespace\` == \\"local\\", FALSE) AND NOT (NOT(\`host.name\` IS NULL) AND COALESCE(\`host.name\` != \\"\\", TRUE))), TO_STRING(user.name), entity.name)
| EVAL entity.name = CASE((COALESCE(\`entity.namespace\` != \\"local\\", TRUE)), TO_STRING(user.name), entity.name),
    entity.confidence = CASE((COALESCE(\`entity.namespace\` != \\"local\\", TRUE)), \\"high\\", entity.confidence)
| EVAL entity.confidence = CASE((COALESCE(\`entity.namespace\` == \\"local\\", FALSE)), \\"medium\\", entity.confidence)
| KEEP entity*,
event*,
user*,
asset*,
data_stream*,
host*,
@timestamp
| SORT entity.EngineMetadata.FirstSeenLogInPage ASC, entity.id ASC
| WHERE entity.EngineMetadata.FirstSeenLogInPage > TO_DATETIME(\\"2022-01-01T12:00:00.000Z\\") 
            OR (entity.EngineMetadata.FirstSeenLogInPage == TO_DATETIME(\\"2022-01-01T12:00:00.000Z\\") 
                AND entity.id > \\"cursor-id\\")
| LIMIT 10000"
`;

exports[`buildCcsLogsExtractionEsqlQuery generates query for generic entity type 1`] = `
"SET unmapped_fields=\\"nullify\\";
FROM remote_cluster:logs-*
    METADATA _index, _id
  | WHERE
      @timestamp >= TO_DATETIME(\\"2022-01-01T00:00:00.000Z\\")
      AND @timestamp <= TO_DATETIME(\\"2022-01-01T23:59:59.999Z\\")
      AND ((entity.id IS NOT NULL AND entity.id != \\"\\"))
| EVAL _src_entity_source0 = MV_FIRST(event.module),
 _src_entity_source1 = MV_FIRST(event.dataset),
 _src_entity_source2 = MV_FIRST(data_stream.dataset),
 _src_entity_source = CASE((_src_entity_source0 IS NOT NULL AND _src_entity_source0 != \\"\\"), _src_entity_source0, (_src_entity_source1 IS NOT NULL AND _src_entity_source1 != \\"\\"), _src_entity_source1, (_src_entity_source2 IS NOT NULL AND _src_entity_source2 != \\"\\"), _src_entity_source2, NULL),
 entity.source = CASE((_src_entity_source IS NULL OR _src_entity_source == \\"\\"), NULL, _src_entity_source)
| EVAL entity.id = entity.id
| STATS
    @timestamp = MAX(@timestamp),
    entity.EngineMetadata.FirstSeenLogInPage = MIN(@timestamp),
    entity.id = LAST(TO_STRING(entity.id), @timestamp) WHERE TO_STRING(entity.id) IS NOT NULL,
 entity.name = LAST(TO_STRING(entity.name), @timestamp) WHERE TO_STRING(entity.name) IS NOT NULL,
 event.module = MV_DEDUPE(TOP(TO_STRING(event.module), 10)) WHERE TO_STRING(event.module) IS NOT NULL,
 event.dataset = MV_DEDUPE(TOP(TO_STRING(event.dataset), 10)) WHERE TO_STRING(event.dataset) IS NOT NULL,
 data_stream.dataset = MV_DEDUPE(TOP(TO_STRING(data_stream.dataset), 50)) WHERE TO_STRING(data_stream.dataset) IS NOT NULL,
 entity.source = MV_DEDUPE(TOP(TO_STRING(entity.source), 50)) WHERE TO_STRING(entity.source) IS NOT NULL,
 entity.type = LAST(TO_STRING(entity.type), @timestamp) WHERE TO_STRING(entity.type) IS NOT NULL,
