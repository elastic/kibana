 host.network.ingress.bytes = MV_SLICE(MV_UNION(recent.host.network.ingress.bytes, host.network.ingress.bytes), 0, 9),
 host.network.ingress.packets = MV_SLICE(MV_UNION(recent.host.network.ingress.packets, host.network.ingress.packets), 0, 9),
 host.pid_ns_ino = MV_SLICE(MV_UNION(recent.host.pid_ns_ino, host.pid_ns_ino), 0, 9),
 host.uptime = MV_SLICE(MV_UNION(recent.host.uptime, host.uptime), 0, 9),
 host.os.family = MV_SLICE(MV_UNION(recent.host.os.family, host.os.family), 0, 9),
 host.os.full = MV_SLICE(MV_UNION(recent.host.os.full, host.os.full), 0, 9),
 host.os.kernel = MV_SLICE(MV_UNION(recent.host.os.kernel, host.os.kernel), 0, 9),
 host.os.platform = MV_SLICE(MV_UNION(recent.host.os.platform, host.os.platform), 0, 9),
 host.os.version = MV_SLICE(MV_UNION(recent.host.os.version, host.os.version), 0, 9),
 host.geo.city_name = MV_SLICE(MV_UNION(recent.host.geo.city_name, host.geo.city_name), 0, 9),
