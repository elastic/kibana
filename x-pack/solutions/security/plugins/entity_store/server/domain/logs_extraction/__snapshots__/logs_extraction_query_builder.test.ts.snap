 host.type = MV_SLICE(MV_UNION(recent.host.type, host.type), 0, 9),
 host.architecture = MV_SLICE(MV_UNION(recent.host.architecture, host.architecture), 0, 9),
 host.boot.id = MV_SLICE(MV_UNION(recent.host.boot.id, host.boot.id), 0, 9),
 host.cpu.usage = COALESCE(recent.host.cpu.usage, host.cpu.usage),
 host.disk.read.bytes = MV_SLICE(MV_UNION(recent.host.disk.read.bytes, host.disk.read.bytes), 0, 9),
 host.disk.write.bytes = MV_SLICE(MV_UNION(recent.host.disk.write.bytes, host.disk.write.bytes), 0, 9),
