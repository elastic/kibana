 host.geo.name = MV_SLICE(MV_UNION(recent.host.geo.name, host.geo.name), 0, 9),
 host.geo.postal_code = MV_SLICE(MV_UNION(recent.host.geo.postal_code, host.geo.postal_code), 0, 9),
