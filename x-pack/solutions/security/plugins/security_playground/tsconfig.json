{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types"
  },
  "include": [
    "common/**/*.ts",
    "public/**/*.ts",
    "public/**/*.tsx",
    "server/**/*.ts",
    "../../typings/**/*"
  ],
  "exclude": ["target/**/*"],
  "kbn_references": [
    "@kbn/core",
    "@kbn/core-plugins-server",
    "@kbn/config-schema",
    "@kbn/core-http-server",
    "@kbn/core-http-request-handler-context-server",
    "@kbn/core-elasticsearch-server",
    "@kbn/spaces-plugin",
    "@kbn/alerting-plugin",
    "@kbn/logging",
    "@kbn/shared-ux-page-kibana-template",
    "@kbn/i18n",
    "@kbn/i18n-react"
  ]
}
