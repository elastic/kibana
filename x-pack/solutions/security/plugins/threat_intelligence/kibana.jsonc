{
  "type": "plugin",
  "id": "@kbn/threat-intelligence-plugin",
  "owner": ["@elastic/security-solution"],
  "group": "security",
  "visibility": "private",
  "plugin": {
    "id": "threatIntelligence",
    "server": true,
    "browser": true,
    "configPath": ["xpack", "threatIntelligence"],
    "requiredPlugins": ["agentBuilder", "features"],
    "optionalPlugins": ["workflowsManagement", "securitySolution", "spaces", "taskManager", "inference"]
  }
}
