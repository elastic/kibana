{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types"
  },
  "include": ["common/**/*", "common/**/*.json", "public/**/*", "server/**/*"],
  "kbn_references": [
    "@kbn/core",
    "@kbn/i18n",
    "@kbn/logging",
    "@kbn/config-schema",
    "@kbn/zod",
    "@kbn/utility-types",
    "@kbn/agent-builder-browser",
    "@kbn/agent-builder-common",
    "@kbn/agent-builder-server",
    "@kbn/core-elasticsearch-server",
    "@kbn/core-http-server",
    "@kbn/core-saved-objects-api-server",
    "@kbn/features-plugin",
    "@kbn/react-kibana-context-render",
    "@kbn/securitysolution-mitre-catalog",
    "@kbn/securitysolution-rules",
    "@kbn/spaces-plugin",
    "@kbn/task-manager-plugin"
  ],
  "exclude": ["target/**/*"]
}
