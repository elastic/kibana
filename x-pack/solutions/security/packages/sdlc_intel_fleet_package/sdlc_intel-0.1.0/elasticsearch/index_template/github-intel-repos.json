{
  "index_patterns": [
    "github-intel-repos"
  ],
  "priority": 200,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "index.lifecycle.name": "sdlc_intel_retention"
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "sync": {
          "properties": {
            "run_id": {
              "type": "keyword"
            },
            "source": {
              "type": "keyword"
            }
          }
        },
        "entity": {
          "properties": {
            "type": {
              "type": "keyword"
            },
            "subtype": {
              "type": "keyword"
            },
            "id": {
              "type": "keyword"
            },
            "url": {
              "type": "keyword"
            },
            "number": {
              "type": "integer"
            }
          }
        },
        "github": {
          "properties": {
            "created_at": {
              "type": "date"
            },
            "updated_at": {
              "type": "date"
            },
            "closed_at": {
              "type": "date"
            },
            "state": {
              "type": "keyword"
            }
          }
        },
        "org": {
          "properties": {
            "login": {
              "type": "keyword"
            }
          }
        },
        "repository": {
          "properties": {
            "name": {
              "type": "keyword"
            },
            "full_name": {
              "type": "keyword"
            }
          }
        },
        "labels": {
          "type": "keyword"
        },
        "people": {
          "properties": {
            "author": {
              "type": "keyword"
            },
            "assignees": {
              "type": "keyword"
            },
            "reviewers": {
              "type": "keyword"
            }
          }
        },
        "repo": {
          "properties": {
            "name": {
              "type": "keyword"
            },
            "full_name": {
              "type": "keyword"
            },
            "description": {
              "type": "text"
            },
            "default_branch": {
              "type": "keyword"
            },
            "is_private": {
              "type": "boolean"
            }
          }
        },
        "payload": {
          "type": "object",
          "enabled": true
        }
      }
    }
  },
  "_meta": {
    "package": {
      "name": "sdlc_intel"
    }
  }
}
