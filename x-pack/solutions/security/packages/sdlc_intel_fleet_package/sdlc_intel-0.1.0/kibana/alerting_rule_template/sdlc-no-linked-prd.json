{
  "id": "sdlc-no-linked-prd",
  "type": "alerting_rule_template",
  "attributes": {
    "name": "SDLC roadmap epics missing PRD link",
    "tags": ["SDLC Intelligence", "planning", "prd"],
    "ruleTypeId": ".es-query",
    "schedule": {
      "interval": "24h"
    },
    "params": {
      "searchType": "esqlQuery",
      "esqlQuery": {
        "esql": "FROM sdlc-epic-phases | WHERE links.prd_url IS NULL AND release.roadmap_stage IS NOT NULL | STATS epics_without_prd = COUNT(*)"
      },
      "timeField": "@timestamp",
      "timeWindowSize": 7,
      "timeWindowUnit": "d",
      "size": 0,
      "thresholdComparator": ">",
      "threshold": [0]
    },
    "alertDelay": {
      "active": 1
    }
  },
  "coreMigrationVersion": "8.8.0",
  "typeMigrationVersion": "10.1.0"
}
