{
  "id": "sdlc-roadmap-unassigned-team",
  "type": "alerting_rule_template",
  "attributes": {
    "name": "SDLC roadmap project items without team assignment",
    "tags": ["SDLC Intelligence", "planning", "team"],
    "ruleTypeId": ".es-query",
    "schedule": {
      "interval": "24h"
    },
    "params": {
      "searchType": "esqlQuery",
      "esqlQuery": {
        "esql": "FROM github-intel-project-items | WHERE roadmap.stage IS NOT NULL AND team_attribution.engineering_team IS NULL | STATS unassigned_items = COUNT(*)"
      },
      "timeField": "@timestamp",
      "timeWindowSize": 7,
      "timeWindowUnit": "d",
      "size": 0,
      "thresholdComparator": ">",
      "threshold": [0]
    },
    "alertDelay": {
      "active": 1
    }
  },
  "coreMigrationVersion": "8.8.0",
  "typeMigrationVersion": "10.1.0"
}
