{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
    "types": ["jest", "node", "react", "@testing-library/jest-dom", "@kbn/ambient-ui-types"]
  },
  "include": ["**/*.ts", "**/*.tsx", ".storybook/**/*.ts"],
  "exclude": ["target/**/*"],
  "kbn_references": [
    "@kbn/i18n",
    "@kbn/i18n-react",
    "@kbn/storybook",
    "@kbn/kibana-react-plugin",
    "@kbn/shared-ux-ai-components",
    "@kbn/react-query",
    "@kbn/data-plugin",
    "@kbn/test-jest-helpers",
    "@kbn/lens-embeddable-utils",
    "@kbn/lens-plugin",
    "@kbn/data-views-plugin",
    "@kbn/ui-actions-plugin",
    "@kbn/es-query"
  ]
}
