{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types"
  },
  "include": [
    "common/**/*",
    "public/**/*",
    "../../../../../typings/**/*",
    "public/**/*.json",
    "server/**/*"
  ],
  "kbn_references": [
    "@kbn/core",
    "@kbn/i18n",
    "@kbn/i18n-react",
    "@kbn/kibana-react-plugin",
    "@kbn/observability-shared-plugin",
    "@kbn/react-kibana-context-render",
    "@kbn/react-kibana-mount",
    "@kbn/shared-ux-router",
    "@kbn/config-schema"
  ],
  "exclude": ["target/**/*"]
}
