      color="danger"
    >
      <EuiDescriptionList
        listItems={
          Array [
            Object {
              "description": <EuiText>
                Forbidden
              </EuiText>,
              "title": "Error",
            },
            Object {
              "description": <React.Fragment>
                <BodyDescription
                  body={
                    Object {
                      "bytes": 1200000,
                      "content": "<http><head><title>The Title</title></head><body></body></http>",
                      "hash": "testhash",
                    }
                  }
                />
                <EuiSpacer
                  size="s"
                />
                <BodyExcerpt
                  content="<http><head><title>The Title</title></head><body></body></http>"
                />
              </React.Fragment>,
              "title": "Response Body",
            },
          ]
        }
      />
    </EuiCallOut>
  </EuiFlexItem>
</EuiFlexGroup>
`;

