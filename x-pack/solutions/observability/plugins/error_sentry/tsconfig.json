{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types"
  },
  "include": [
    "index.ts",
    "common/**/*.ts",
    "public/**/*.ts",
    "public/**/*.tsx",
    "server/**/*.ts",
    "../../../../../typings/**/*"
  ],
  "exclude": [
    "target/**/*"
  ],
  "kbn_references": [
    "@kbn/core",
    "@kbn/core-http-server",
    "@kbn/core-http-server-utils",
    "@kbn/workflows-extensions",
    "@kbn/workflows-management-plugin",
    "@kbn/workflows",
    "@kbn/zod",
    "@kbn/i18n",
    "@kbn/i18n-react",
    "@kbn/config-schema",
    "@kbn/agent-builder-browser",
    "@kbn/agent-builder-common"
  ]
}
