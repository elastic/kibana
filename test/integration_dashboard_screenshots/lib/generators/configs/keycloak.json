{
  "package": "keycloak",
  "dataStreams": [
    {
      "dataset": "keycloak.log",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "event.action",
        "keycloak.login.auth_method",
        "keycloak.login.type",
        "source.ip",
        "user.name"
      ],
      "filterValues": {}
    }
  ]
}