{
  "package": "beelzebub",
  "dataStreams": [
    {
      "dataset": "beelzebub.logs",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "beelzebub.event.Password",
        "beelzebub.event.Protocol",
        "http.request.method",
        "url.path",
        "url.port",
        "user.name",
        "user_agent.original"
      ],
      "filterValues": {}
    }
  ]
}