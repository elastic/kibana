{
  "package": "qualys_gav",
  "dataStreams": [
    {
      "dataset": "qualys_gav.asset",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "cloud.provider",
        "host.id",
        "host.os.name",
        "host.os.type",
        "host.type",
        "labels.is_transform_source",
        "qualys_gav.asset.hardware.category",
        "qualys_gav.asset.hardware.category1",
        "qualys_gav.asset.hardware.category2",
        "qualys_gav.asset.hardware.product_name",
        "qualys_gav.asset.last_location.country",
        "qualys_gav.asset.operating_system.category2",
        "qualys_gav.asset.software_list_data.software.category1",
        "qualys_gav.asset.software_list_data.software.product_name",
        "qualys_gav.asset.software_list_data.software.publisher"
      ],
      "filterValues": {
        "qualys_gav.asset.operating_system.category2": [
          "Client",
          "Server"
        ],
        "qualys_gav.asset.hardware.category2": [
          "Server"
        ],
        "labels.is_transform_source": [
          "false"
        ]
      }
    }
  ]
}