        "infoblox_threat_defense.event.outcome",
        "infoblox_threat_defense.event.status",
        "infoblox_threat_defense.event.transport_protocol",
        "network.application",
        "network.transport",
        "rule.name",
        "source.ip",
        "source.mac",
        "source.port",
        "source.user.name",
