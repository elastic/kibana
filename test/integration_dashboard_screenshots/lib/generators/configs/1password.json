{
  "package": "1password",
  "dataStreams": [
    {
      "dataset": "1password.audit_events",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "event.action",
        "onepassword.object_type",
        "user.id"
      ],
      "filterValues": {}
    },
    {
      "dataset": "1password.item_usages",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "onepassword.item_uuid",
        "onepassword.vault_uuid",
        "user.email",
        "user.full_name",
        "user.id"
      ],
      "filterValues": {}
    },
    {
      "dataset": "1password.signin_attempts",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "event.action"
      ],
      "filterValues": {
        "event.action": [
          "success",
          "firewall_reported_success"
        ]
      }
    }
  ]
}