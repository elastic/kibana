{
  "package": "trellix_epo_cloud",
  "dataStreams": [
    {
      "dataset": "trellix_epo_cloud.device",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "host.os.platform",
        "host.os.type",
        "host.os.version",
        "trellix_epo_cloud.device.attributes.cpu.type",
        "trellix_epo_cloud.device.attributes.is_portable",
        "trellix_epo_cloud.device.attributes.tags"
      ],
      "filterValues": {
        "trellix_epo_cloud.device.attributes.is_portable": [
          "portable",
          "non-portable"
        ]
      }
    },
    {
      "dataset": "trellix_epo_cloud.event",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "event.id",
        "event.severity",
        "threat.indicator.description",
        "trellix_epo_cloud.event.attributes.threat.category",
        "trellix_epo_cloud.event.attributes.threat.type"
      ],
      "filterValues": {}
    }
  ]
}