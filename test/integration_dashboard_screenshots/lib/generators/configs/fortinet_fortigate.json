{
  "package": "fortinet_fortigate",
  "dataStreams": [
    {
      "dataset": "fortinet_fortigate.log",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "destination.as.organization.name",
        "destination.geo.country_name",
        "destination.geo.location",
        "event.action",
        "event.category",
        "event.duration",
        "event.outcome",
        "fortinet.firewall.type",
        "log.level",
        "log.syslog.severity.code",
        "network.bytes",
        "network.direction",
        "network.transport",
        "source.as.organization.name",
        "source.geo.country_name",
        "source.geo.location"
      ],
      "filterValues": {}
    }
  ]
}