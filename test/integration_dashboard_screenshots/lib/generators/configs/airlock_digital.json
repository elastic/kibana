        "file.name",
        "host.hostname",
        "process.parent.name",
        "rule.name",
        "user.name"
      ],
      "filterValues": {}
    },
    {
      "dataset": "airlock_digital.server_activities",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "airlock_digital.server_activities.task",
