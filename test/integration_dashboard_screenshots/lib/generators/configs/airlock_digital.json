        "airlock_digital.agent.poilcy_details.trusted_config",
        "airlock_digital.agent.status_value",
        "host.hostname",
        "host.id",
        "host.os.full",
        "rule.id",
        "rule.name",
        "user.name"
      ],
      "filterValues": {}
    },
    {
      "dataset": "airlock_digital.execution_histories",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
