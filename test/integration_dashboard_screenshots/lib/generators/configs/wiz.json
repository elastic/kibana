{
  "package": "wiz",
  "dataStreams": [
    {
      "dataset": "wiz.audit",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "event.action",
        "event.id",
        "source.ip",
        "user.id"
      ],
      "filterValues": {}
    },
    {
      "dataset": "wiz.cloud_configuration_finding",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "event.id",
        "resource.id",
        "resource.name",
        "resource.sub_type",
        "result.evaluation",
        "rule.id",
        "rule.name"
      ],
      "filterValues": {
        "result.evaluation": [
          "FAILED"
        ]
      }
    },
    {
      "dataset": "wiz.cloud_configuration_finding_full_posture",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "event.id",
        "wiz.audit.status",
        "wiz.issue.status.value"
      ],
      "filterValues": {}
    },
    {
      "dataset": "wiz.defend",
      "indexPattern": "logs-*",
      "docTarget": 570,
      "fields": [
        "event.action",
        "event.id",
        "event.provider",
        "rule.name",
        "source.geo.country_iso_code",
        "threat.indicator.id",
        "threat.indicator.reference",
        "threat.tactic.id",
        "threat.technique.id",
        "wiz.defend.created_at",
        "wiz.defend.id",
        "wiz.defend.severity",
        "wiz.defend.triggering_event.actor.type",
        "wiz.defend.triggering_event.resources.cloud_account.cloud_platform",
        "wiz.defend.triggering_event.resources.cloud_account.id",
        "wiz.defend.triggering_event.resources.type",
        "wiz.defend.triggering_event.runtime_details.process_tree.command",
        "wiz.defend.triggering_event.runtime_details.process_tree.container.id",
        "wiz.defend.triggering_event.runtime_details.process_tree.container.name"
      ],
      "filterValues": {}
    },
    {
      "dataset": "wiz.issue",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "event.created",
        "event.id",
        "wiz.issue.entity_snapshot.type",
        "wiz.issue.severity"
      ],
      "filterValues": {}
    },
    {
      "dataset": "wiz.vulnerability",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "vulnerability.description",
        "vulnerability.id",
        "vulnerability.severity",
        "wiz.vulnerability.detection_method",
        "wiz.vulnerability.id",
        "wiz.vulnerability.impact_score",
        "wiz.vulnerability.status",
        "wiz.vulnerability.vulnerable_asset.cloud.provider_url",
        "wiz.vulnerability.vulnerable_asset.has_limited_internet_exposure",
        "wiz.vulnerability.vulnerable_asset.has_wide_internet_exposure",
        "wiz.vulnerability.vulnerable_asset.ip_addresses"
      ],
      "filterValues": {}
    }
  ]
}