{
  "package": "fireeye",
  "dataStreams": [
    {
      "dataset": "fireeye.nx",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "destination.bytes",
        "destination.ip",
        "fireeye.nx.flow.state",
        "network.protocol",
        "network.transport",
        "source.bytes",
        "source.ip"
      ],
      "filterValues": {}
    }
  ]
}