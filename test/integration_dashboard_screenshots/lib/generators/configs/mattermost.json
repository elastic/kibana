{
  "package": "mattermost",
  "dataStreams": [
    {
      "dataset": "mattermost.audit",
      "indexPattern": "logs-*",
      "docTarget": 500,
      "fields": [
        "event.action",
        "event.outcome",
        "source.ip",
        "user.id",
        "user.target.name"
      ],
      "filterValues": {}
    }
  ]
}