# Shared remote Elasticsearch (required)
ELASTICSEARCH_URL=https://your-deployment.es.us-west2.gcp.elastic-cloud.com
ES_USER=elastic
ES_PASSWORD=<your-password>

# Service account token for local Kibana -> ES connection
# Kibana blocks elasticsearch.username=elastic; use a service account token instead.
# Generate one with:
#   curl -u elastic:<password> -X POST "$ELASTICSEARCH_URL/_security/service/elastic/kibana/credential/token/my-token-name"
KIBANA_SERVICE_ACCOUNT_TOKEN=<your-service-account-token>

# Local Kibana
KIBANA_URL=http://localhost:5601

# Optional: limit to specific packages (comma-separated)
# PACKAGES=nginx,apache,system
