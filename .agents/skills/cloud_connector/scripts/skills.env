# Cloud Connector Skills — Global Environment Config
# DO NOT COMMIT — listed in .gitignore

# ---------------------------------------------------------------
# Directories
# ---------------------------------------------------------------
KIBANA_DIR="$HOME/elastic/kibana"
INTEGRATIONS_DIR="$HOME/elastic/integrations"
DOCS_REPO="$HOME/elastic/docs.elastic.dev"

# ---------------------------------------------------------------
# QAF Deployment
# ---------------------------------------------------------------
PRODUCTION_REGION="gcp-us-west2"
QA_REGION="aws-eu-west-1"
CLOUD_JSON_PATH="$HOME/.elastic/cloud.json"
QAF_DOCS_URL="https://docs.elastic.dev/appex-qa/qaf/getting-started"

# ---------------------------------------------------------------
# Elastic Package
# ---------------------------------------------------------------
# Override if elastic-package is not on PATH
# ELASTIC_PACKAGE_BIN="elastic-package"

# ---------------------------------------------------------------
# FTR Tests
# ---------------------------------------------------------------
FLEET_PACKAGE_REGISTRY_PORT="12345"

# ---------------------------------------------------------------
# Node
# ---------------------------------------------------------------
# NVM_DIR is auto-detected, override if non-standard
# NVM_DIR="$HOME/.nvm"
