# Cloud Connector Credentials — DO NOT COMMIT
# Used by cloud_connector_e2e_setup.sh to populate API requests
# Edit values below then run: cce2e

# ---------------------------------------------------------------
# Kibana connection
# ---------------------------------------------------------------
KIBANA_URL="http://localhost:5601"
KIBANA_USER="elastic"
KIBANA_PASSWORD="changeme"

# ---------------------------------------------------------------
# AWS Cloud Connector Credentials
# ---------------------------------------------------------------
AWS_ROLE_ARN="arn:aws:iam::123456789012:role/elastic-cloud-connector-role"
AWS_EXTERNAL_ID="elastic-external-id-abc123"
AWS_CONNECTOR_NAME="aws-cloud-connector-dev"

# ---------------------------------------------------------------
# GCP Cloud Connector Credentials (for future use)
# ---------------------------------------------------------------
# GCP_SERVICE_ACCOUNT="my-sa@my-project.iam.gserviceaccount.com"
# GCP_AUDIENCE="//iam.googleapis.com/projects/123456789/locations/global/workloadIdentityPools/elastic-pool/providers/elastic-provider"
# GCP_CREDENTIALS_CLOUD_CONNECTOR_ID="gcp-connector-id-12345"
# GCP_CONNECTOR_NAME="gcp-cloud-connector-dev"

# ---------------------------------------------------------------
# Azure Cloud Connector Credentials (for future use)
# ---------------------------------------------------------------
# AZURE_TENANT_ID="00000000-0000-0000-0000-000000000000"
# AZURE_CLIENT_ID="11111111-1111-1111-1111-111111111111"
# AZURE_CREDENTIALS_CLOUD_CONNECTOR_ID="azure-connector-id-12345"
# AZURE_CONNECTOR_NAME="azure-cloud-connector-dev"

# ---------------------------------------------------------------
# Integration packages
# ---------------------------------------------------------------
CSPM_PACKAGE="cloud_security_posture"
CSPM_PACKAGE_VERSION="3.3.0-preview06"
ASSET_INVENTORY_PACKAGE="cloud_asset_inventory"
ASSET_INVENTORY_PACKAGE_VERSION="1.5.0-preview04"
