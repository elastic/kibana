{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "module": "commonjs",
    "outDir": "target/types",
    "types": ["node", "jest"],
    "baseUrl": ".",
    "paths": {
      "#pipeline-utils": ["pipeline-utils/index.ts"],
      "#pipeline-utils/*": ["pipeline-utils/*"]
    }
  },
  "include": [
    "pipeline-utils/**/*",
    "pipelines/**/*",
    "scripts/**/*",
    "pipelines/flaky_tests/groups.json",
    "pull_requests.json",
    "pipeline-resource-definitions/**/*.ts"
  ],
  "exclude": ["target/**/*"]
}
