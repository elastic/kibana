#!/usr/bin/env bash
#
# List packages affected by changes (compared to merge base).
# Delegates to the repo script scripts/list_affected_packages.js.
#
# Usage:
#   .buildkite/scripts/list-affected-packages [options]
#
# Options: --deep, --json, --merge-base <commit>, --strategy <git|moon>
# See: yarn list-affected-packages --help (or scripts/list_affected_packages.js)
#
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
exec node --no-experimental-require-module scripts/list_affected_packages.js "$@"
