#!/usr/bin/env bash

set -euo pipefail

# Only optimize checkout for the Build Kibana Distribution step;
# all other steps fall through to the default Buildkite checkout.
if [[ "${BUILDKITE_LABEL:-}" != "Build Kibana Distribution" ]]; then
  return 0 2>/dev/null || exit 0
fi

MIRROR_DIR="/opt/git-mirrors/git-github-com-elastic-kibana-git"
CHECKOUT_DIR="${BUILDKITE_BUILD_CHECKOUT_PATH}"
REPO_URL="${BUILDKITE_REPO:-git@github.com:elastic/kibana.git}"
PR_NUMBER="${GITHUB_PR_NUMBER:-}"

mkdir -p "$CHECKOUT_DIR"
cd "$CHECKOUT_DIR"

if [[ -d ".git" ]]; then
  echo "~~~ Reusing existing checkout, resetting"
  git clean -ffxdq
  git reset --hard HEAD 2>/dev/null || true
else
  echo "~~~ Shallow clone with local mirror"

  CLONE_ARGS=(--depth=1 --no-tags --single-branch)

  if [[ -d "$MIRROR_DIR" ]]; then
    CLONE_ARGS+=(--reference "$MIRROR_DIR" --dissociate)
  fi

  git clone "${CLONE_ARGS[@]}" -- "$REPO_URL" .
fi

if [[ -n "$PR_NUMBER" ]]; then
  echo "~~~ Fetching PR #${PR_NUMBER} head (shallow)"
  git fetch --depth=1 --no-tags origin "refs/pull/${PR_NUMBER}/head"
  git checkout -f FETCH_HEAD
else
  echo "~~~ Fetching commit ${BUILDKITE_COMMIT} (shallow)"
  git fetch --depth=1 --no-tags origin "$BUILDKITE_COMMIT"
  git checkout -f "$BUILDKITE_COMMIT"
fi

echo "Checked out $(git rev-parse HEAD)"
