    { "id": "#15-role-acct",  "challenges": ["rule", "embedding"],  "pairs": [["er-15-svc-1", "er-15-svc-2"], ["er-15-svc-1", "er-15-svc-3"], ["er-15-svc-1", "er-15-admin"], ["er-15-svc-2", "er-15-svc-3"], ["er-15-svc-2", "er-15-admin"], ["er-15-svc-3", "er-15-admin"]], "note": "3 service accounts + 1 admin share noreply@; DIFFERENT identities. Rule wrongly links all 4; embedding role-account guard should skip" },
    { "id": "#21-distractor", "challenges": ["embedding"],          "pairs": [["er-21-nora", "er-21-levi-1"], ["er-21-nora", "er-21-levi-2"]],     "note": "Bianca Moreau must NOT link to Bruno Moreno despite shared domain + similar surname tail" },
    { "id": "#24-homonyms",   "challenges": ["embedding"],          "pairs": [["er-24-corp", "er-24-acme"], ["er-24-corp", "er-24-family"], ["er-24-acme", "er-24-family"]], "note": "three different John Smiths on different domains; embedding over-link risk" }
