    { "id": "#7-stray",       "challenges": ["rule"],               "pairs": [["er-7-stray", "er-7-t1"], ["er-7-stray", "er-7-t2"]],             "note": "ambiguous bucket; stray stays unresolved" },
    { "id": "#8-no-email",    "challenges": ["rule"],               "pairs": [],                                                                  "note": "single entity, no email; must stay unresolved (no pair to assert, checked via unresolved set)" },
