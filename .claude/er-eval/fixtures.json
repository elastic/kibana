  "clusters": [
    { "id": "#1-basic",        "members": ["er-1-okta-user", "er-1-entra-user"],                 "target": "er-1-okta-user",  "resolvableBy": "rule",      "expectedSize": 2, "note": "okta + entra_id, same email" },
    { "id": "#2-ns-priority",  "members": ["er-2-ad-user", "er-2-okta-user", "er-2-entra-user"], "target": "er-2-ad-user",    "resolvableBy": "rule",      "expectedSize": 3, "note": "AD wins over okta/entra" },
    { "id": "#3-alphabetical", "members": ["er-3-a-user", "er-3-b-user"],                        "target": "er-3-a-user",     "resolvableBy": "rule",      "expectedSize": 2, "note": "neither ns in priority list; alphabetical entity.id" },
    { "id": "#4-extend",       "members": ["er-4-target", "er-4-alias", "er-4-new"],             "target": "er-4-target",     "resolvableBy": "manual",    "expectedSize": 3, "note": "manual link alias->target, then er-4-new joins via rule" },
    { "id": "#5-incr-a",       "members": ["er-5-a1", "er-5-a2"],                                "target": "er-5-a1",         "resolvableBy": "rule",      "expectedSize": 2, "note": "incremental batch A" },
    { "id": "#5-incr-b",       "members": ["er-5-b1", "er-5-b2"],                                "target": "er-5-b1",         "resolvableBy": "rule",      "expectedSize": 2, "note": "incremental batch B (later watermark)" },
    { "id": "#6-single-pair",  "members": ["er-6-single-a", "er-6-single-b"],                    "target": "er-6-single-b",   "resolvableBy": "rule",      "expectedSize": 2, "note": "AD wins; er-6-multi excluded (multi-value email)" },
    { "id": "#7-group-1",      "members": ["er-7-t1", "er-7-e1"],                                "target": "er-7-t1",         "resolvableBy": "manual",    "expectedSize": 2, "note": "manual link e1->t1" },
    { "id": "#7-group-2",      "members": ["er-7-t2", "er-7-e2"],                                "target": "er-7-t2",         "resolvableBy": "manual",    "expectedSize": 2, "note": "manual link e2->t2" },
    { "id": "#11-sparse",      "members": ["er-11-okta", "er-11-entra"],                         "target": "er-11-okta",      "resolvableBy": "rule",      "expectedSize": 2, "note": "email-only, both sparse" },
    { "id": "#12-asymmetric",  "members": ["er-12-ad", "er-12-okta"],                            "target": "er-12-ad",        "resolvableBy": "rule",      "expectedSize": 2, "note": "AD rich, okta sparse; same email" },
    { "id": "#13-case",        "members": ["er-13-okta", "er-13-entra"],                         "target": "er-13-okta",      "resolvableBy": "embedding", "expectedSize": 2, "note": "Alice@Corp.com vs alice@corp.com; rule keyword-case-sensitive (silent), embedding lowercases" },
    { "id": "#14-plus-alias",  "members": ["er-14-okta", "er-14-entra"],                         "target": "er-14-okta",      "resolvableBy": "embedding", "expectedSize": 2, "note": "bob+work@ vs bob@ (same mailbox); rule silent; embedding may catch (hard)" },
    { "id": "#16-six-way",     "members": ["er-16-ad", "er-16-okta", "er-16-entra", "er-16-slack", "er-16-github", "er-16-m365"], "target": "er-16-ad", "resolvableBy": "rule", "expectedSize": 6, "note": "six-way collision, AD wins" },
    { "id": "#17-m365",        "members": ["er-17-m365", "er-17-okta", "er-17-entra"],           "target": "er-17-okta",      "resolvableBy": "rule",      "expectedSize": 3, "note": "M365 mapped but not in NAMESPACE_PRIORITY; okta wins" },
    { "id": "#18-name-only",   "members": ["er-18-a", "er-18-b"],                                "target": "er-18-a",         "resolvableBy": "embedding", "expectedSize": 2, "note": "same full_name, no email; rule silent; embedding aspirational (name field is synthetic id, noisy)" },
    { "id": "#19-variants",    "members": ["er-19-okta", "er-19-entra", "er-19-ad", "er-19-slack", "er-19-github"], "target": "er-19-okta", "resolvableBy": "embedding", "expectedSize": 5, "note": "one canonical Nora Paterson + 4 username variants, no shared email" },
    { "id": "#20-typo",        "members": ["er-20-okta", "er-20-entra"],                         "target": "er-20-okta",      "resolvableBy": "embedding", "expectedSize": 2, "note": "Kessler vs Kesler spelling drift; rules silent (diff email keyword)" },
    { "id": "#21-levi",        "members": ["er-21-levi-1", "er-21-levi-2"],                      "target": "er-21-levi-1",    "resolvableBy": "embedding", "expectedSize": 2, "note": "two Bruno Moreno accounts = same human" },
    { "id": "#22-cross-field", "members": ["er-22-display", "er-22-user"],                       "target": "er-22-display",   "resolvableBy": "embedding", "expectedSize": 2, "note": "full_name 'Marcus Liu' vs user.name 'marcus.liu'; each missing the other's field" },
    { "id": "#23-initial",     "members": ["er-23-initial", "er-23-full"],                       "target": "er-23-initial",   "resolvableBy": "embedding", "expectedSize": 2, "note": "C. Okonkwo vs Chidi Okonkwo" },
    { "id": "#25-accent",      "members": ["er-25-accent", "er-25-ascii"],                       "target": "er-25-accent",    "resolvableBy": "embedding", "expectedSize": 2, "note": "José García vs Jose Garcia" },
    { "id": "#26-name-order",  "members": ["er-26-western", "er-26-eastern"],                    "target": "er-26-western",   "resolvableBy": "embedding", "expectedSize": 2, "note": "Wei Chen vs Chen Wei" },
    { "id": "#27-married",     "members": ["er-27-maiden", "er-27-married"],                     "target": "er-27-maiden",    "resolvableBy": "embedding", "expectedSize": 2, "note": "Hana Okafor vs Hana Okafor-Bello" }
