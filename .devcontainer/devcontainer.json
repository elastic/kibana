{
  "name": "Kibana",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "KBN_DIR": "${containerWorkspaceFolder}"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "ms-azuretools.vscode-docker",
        "editorconfig.editorconfig",
        "timonwong.shellcheck",
        "eamodio.gitlens",
        "github.vscode-pull-request-github",
        "anthropic.claude-code"
      ]
    }
  },
  "runArgs": [],
  "forwardPorts": [
    9200,
    5601,
    9229,
    9230,
    9231,
    9001
  ],
  "postStartCommand": "${containerWorkspaceFolder}/.ona/post_start.sh",
  "mounts": [
    "source=kibana-node-modules,target=${containerWorkspaceFolder}/node_modules,type=volume",
    "source=kibana-es-data,target=${containerWorkspaceFolder}/.es,type=volume",
    "source=kibana-target,target=${containerWorkspaceFolder}/target,type=volume"
  ],
  "remoteUser": "vscode",
  "containerEnv": {
    "KBN_DIR": "${containerWorkspaceFolder}",
    "ANTHROPIC_BASE_URL": "https://access-broker.kibana.dev/proxy/kibana.litellm",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "llm-gateway/claude-opus-4-8",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "llm-gateway/claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "llm-gateway/claude-haiku-4-5",
    "CLAUDE_CODE_SUBAGENT_MODEL": "llm-gateway/claude-opus-4-8"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "dockerDashComposeVersion": "latest"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "installDirectlyFromGitHubRelease": true,
      "version": "latest"
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
  }
}
