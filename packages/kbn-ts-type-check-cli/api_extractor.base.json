{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",

  "compiler": {
    "tsconfigFilePath": "<projectFolder>/tsconfig.type_check.json"
  },

  "mainEntryPointFilePath": "<projectFolder>/target/types/index.d.ts",

  "apiReport": {
    "enabled": false
  },

  "docModel": {
    "enabled": false
  },

  "dtsRollup": {
    "enabled": true,
    "untrimmedFilePath": "<projectFolder>/target/types-bundled/index.d.ts",
    "publicTrimmedFilePath": "<projectFolder>/target/types-bundled/index.public.d.ts"
  }
}
