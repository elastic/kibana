{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "outDir": "target/types",
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
  },
  "include": ["**/*.ts"],
  "exclude": [
    "target/**/*"
  ],
  "kbn_references": [
    "@kbn/repo-info",
  ],
}
