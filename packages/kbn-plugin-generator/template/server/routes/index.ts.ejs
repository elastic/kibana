import type { IRouter } from '@kbn/core/server';


export function defineRoutes(router: IRouter) {
  router.get(
    {
      path: '/api/<%= snakeCase(name) %>/example',
      security: {
        authz: {
          enabled: false,
          reason:
            'Example route that returns non-sensitive timestamp data; replace with appropriate authz configuration for real endpoints.',
        },
      },
      validate: false,
    },
    async (context, request, response) => {
      return response.ok({
        body: {
          time: new Date().toISOString(),
        },
      });
    }
  );
}
