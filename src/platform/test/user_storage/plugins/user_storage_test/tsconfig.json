{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
  },
  "include": [
    "server/**/*.ts",
    "public/**/*.ts",
    "public/**/*.tsx",
    "../../../../../../typings/**/*",
  ],
  "exclude": [
    "target/**/*",
  ],
  "kbn_references": [
    "@kbn/core",
    "@kbn/core-user-storage-browser",
    "@kbn/zod",
  ]
}
