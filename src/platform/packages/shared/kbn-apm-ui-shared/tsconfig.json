{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
    "types": ["jest", "node", "react"]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["target/**/*"],
  "kbn_references": [
    "@kbn/i18n",
    "@kbn/i18n-react",
    "@kbn/charts-theme",
    "@kbn/apm-types-shared",
    "@kbn/custom-icons",
    "@kbn/ebt-click",
    // TODO: LatencyAggregationType lives in x-pack — evaluate whether it should
    // move to @kbn/apm-types-shared (a src package) before this stabilises.
    "@kbn/apm-types",
    "@kbn/core-http-browser",
    "@kbn/deeplinks-observability",
  ]
}
