{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
    "types": [
      "jest",
      "node"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "target/**/*"
  ],
  "kbn_references": [
    "@kbn/data-views-plugin",
    "@kbn/es-query",
    "@kbn/expressions-plugin",
    "@kbn/esql-utils",
    "@kbn/field-types",
    "@kbn/core-saved-objects-common",
    "@kbn/crypto-browser",
    "@kbn/data-view-utils"
  ]
}
