    "types": ["jest", "react", "@testing-library/jest-dom", "@kbn/ambient-ui-types"]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["target/**/*"],
  "kbn_references": [
    "@kbn/core-notifications-browser",
    "@kbn/core-ui-settings-browser",
    "@kbn/core-user-profile-browser",
    "@kbn/core-user-storage-browser",
