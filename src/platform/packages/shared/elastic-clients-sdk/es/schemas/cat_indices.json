{
  "type": "object",
  "properties": {
    "index": {
      "description": "Comma-separated list of data streams, indices, and aliases used to limit the request. Supports wildcards (`*`). To target all data streams and indices, omit this parameter or use `*` or `_all`.",
      "$ref": "#/$defs/Indices",
      "x-found-in": "path"
    },
    "expand_wildcards": {
      "description": "The type of index that wildcard patterns can match.",
      "$ref": "#/$defs/ExpandWildcards",
      "x-found-in": "query"
    },
    "health": {
      "description": "The health status used to limit returned indices. By default, the response includes indices of any health status.",
      "$ref": "#/$defs/HealthStatus",
      "x-found-in": "query"
    },
    "include_unloaded_segments": {
      "type": "boolean",
      "description": "If true, the response includes information from segments that are not loaded into memory.",
      "x-found-in": "query"
    },
    "pri": {
      "type": "boolean",
      "description": "If true, the response only includes information from primary shards.",
      "x-found-in": "query"
    },
    "master_timeout": {
      "description": "Period to wait for a connection to the master node.",
      "$ref": "#/$defs/Duration",
      "x-found-in": "query"
    },
    "h": {
      "description": "A comma-separated list of columns names to display. It supports simple wildcards.",
      "$ref": "#/$defs/CatCatIndicesColumns",
      "x-found-in": "query"
    },
    "s": {
      "description": "List of columns that determine how the table should be sorted. Sorting defaults to ascending and can be changed by setting `:asc` or `:desc` as a suffix to the column name.",
      "$ref": "#/$defs/Names",
      "x-found-in": "query"
    }
  },
  "$defs": {
    "IndexName": {
      "type": "string"
    },
