    },
    "SecurityHasPrivilegesApplicationPrivilegesCheck": {
      "type": "object",
      "properties": {
        "application": {
          "type": "string",
          "description": "The name of the application."
        },
        "privileges": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "A list of the privileges that you want to check for the specified resources. It may be either application privilege names or the names of actions that are granted by those privileges"
        },
        "resources": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "A list of resource names against which the privileges should be checked."
        }
      },
      "required": [
        "application",
        "privileges",
        "resources"
      ]
    },
