    },
    "max_outstanding_read_requests": {
      "$ref": "#/$defs/long",
      "x-found-in": "body"
    },
    "max_outstanding_write_requests": {
      "$ref": "#/$defs/long",
      "x-found-in": "body"
    },
    "max_read_request_operation_count": {
      "$ref": "#/$defs/long",
      "x-found-in": "body"
    },
    "max_read_request_size": {
      "type": "string",
      "x-found-in": "body"
    },
    "max_retry_delay": {
      "$ref": "#/$defs/Duration",
      "x-found-in": "body"
    },
    "max_write_buffer_count": {
      "$ref": "#/$defs/long",
      "x-found-in": "body"
    },
    "max_write_buffer_size": {
      "type": "string",
      "x-found-in": "body"
    },
    "max_write_request_operation_count": {
      "$ref": "#/$defs/long",
      "x-found-in": "body"
    },
    "max_write_request_size": {
      "type": "string",
      "x-found-in": "body"
    },
    "read_poll_timeout": {
