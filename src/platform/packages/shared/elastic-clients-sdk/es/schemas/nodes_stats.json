          }
        }
      ]
    },
    "CommonStatsFlag": {
      "type": "string",
      "enum": [
        "_all",
        "store",
        "indexing",
        "get",
        "search",
        "merge",
        "flush",
        "refresh",
        "query_cache",
        "fielddata",
        "docs",
        "warmer",
        "completion",
