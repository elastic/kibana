{
  "type": "object",
  "properties": {
    "node_id": {
      "description": "List of node IDs or names used to limit returned information.",
      "$ref": "#/$defs/NodeIds",
      "x-found-in": "path"
    },
    "ignore_idle_threads": {
      "type": "boolean",
      "description": "If true, known idle threads (e.g. waiting in a socket select, or to get a task from an empty queue) are filtered out.",
      "x-found-in": "query"
    },
    "interval": {
      "description": "The interval to do the second sampling of threads.",
      "$ref": "#/$defs/Duration",
      "x-found-in": "query"
    },
    "snapshots": {
      "description": "Number of samples of thread stacktrace.",
      "$ref": "#/$defs/long",
      "x-found-in": "query"
    },
    "threads": {
      "description": "Specifies the number of hot threads to provide information for.",
      "$ref": "#/$defs/long",
      "x-found-in": "query"
    },
    "timeout": {
      "description": "Period to wait for a response. If no response is received before the timeout expires, the request fails and returns an error.",
      "$ref": "#/$defs/Duration",
      "x-found-in": "query"
    },
    "type": {
      "description": "The type to sample.",
      "$ref": "#/$defs/ThreadType",
      "x-found-in": "query"
    },
    "sort": {
      "description": "The sort order for 'cpu' type",
      "$ref": "#/$defs/ThreadType",
      "x-found-in": "query"
    }
  },
  "$defs": {
    "NodeId": {
      "type": "string"
    },
    "NodeIds": {
      "anyOf": [
        {
          "$ref": "#/$defs/NodeId"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NodeId"
          }
        }
      ]
    },
    "Duration": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number",
          "const": -1
        },
        {
          "type": "number",
          "const": 0
        }
      ]
    },
    "long": {
      "type": "number"
    },
    "ThreadType": {
      "type": "string",
      "enum": [
        "cpu",
        "wait",
        "block",
        "gpu",
        "mem"
      ]
    }
  }
}
