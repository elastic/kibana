{
  "type": "object",
  "properties": {
    "transform_id": {
      "description": "A transform identifier or a wildcard expression. If you do not specify one of these options, the API returns information for all transforms.",
      "$ref": "#/$defs/Id",
      "x-found-in": "path"
    },
    "allow_no_match": {
      "type": "boolean",
      "description": "Specifies what to do when the request: contains wildcard expressions and there are no transforms that match; contains the `_all` string or no identifiers and there are no matches; contains wildcard expressions and there are only partial matches. If `true`, it returns an empty transforms array when there are no matches and the subset of results when there are partial matches. If `false`, the request returns a 404 status code when there are no matches or only partial matches.",
      "x-found-in": "query"
    },
    "from": {
      "description": "Skips the specified number of transforms.",
      "$ref": "#/$defs/integer",
      "x-found-in": "query"
    },
    "h": {
      "description": "Comma-separated list of column names to display.",
      "$ref": "#/$defs/CatCatTransformColumns",
      "x-found-in": "query"
    },
    "s": {
      "description": "Comma-separated list of column names or column aliases used to sort the response.",
      "$ref": "#/$defs/CatCatTransformColumns",
      "x-found-in": "query"
    },
    "size": {
      "description": "The maximum number of transforms to obtain.",
      "$ref": "#/$defs/integer",
      "x-found-in": "query"
    }
  },
