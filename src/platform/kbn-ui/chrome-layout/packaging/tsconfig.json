{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
    "noEmit": true,
    "jsx": "react",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": false,
    "paths": {
      "@kbn/ui-chrome-layout-constants": [
        "src/platform/kbn-ui/chrome-layout-constants/target/index.d.ts"
      ],
      "@kbn/ui-chrome-layout-utils": [
        "src/platform/kbn-ui/chrome-layout-utils/target/index.d.ts"
      ]
    }
  },
  "include": [
    "react/**/*.ts",
    "react/**/*.tsx",
    "../src/**/*.ts",
    "../src/**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
