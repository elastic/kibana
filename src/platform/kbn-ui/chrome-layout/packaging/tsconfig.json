{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
    "noEmit": true,
    "jsx": "react",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": false,
    "paths": {
      "@kbn/core-chrome-layout-constants": [
        "./react/services/layout_constants.ts"
      ],
      "@kbn/core-chrome-layout-utils": [
        "./react/services/layout_utils.ts"
      ]
    }
  },
  "include": [
    "react/**/*.ts",
    "react/**/*.tsx",
    "../layout.tsx",
    "../layout.component.tsx",
    "../layout.styles.ts",
    "../layout.types.ts",
    "../layout_config_context.tsx",
    "../layout_global_css.tsx",
    "../layout_state_context.tsx",
    "../types.ts",
    "../application/**/*.ts",
    "../application/**/*.tsx",
    "../banner/**/*.ts",
    "../banner/**/*.tsx",
    "../debug/**/*.ts",
    "../debug/**/*.tsx",
    "../footer/**/*.ts",
    "../footer/**/*.tsx",
    "../header/**/*.ts",
    "../header/**/*.tsx",
    "../navigation/**/*.ts",
    "../navigation/**/*.tsx",
    "../sidebar/**/*.ts",
    "../sidebar/**/*.tsx",
    "../layouts/**/*.ts",
    "../layouts/**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
