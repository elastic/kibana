{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
    "types": [
      "jest",
      "@testing-library/jest-dom",
      "node",
      "react",
      "@kbn/ambient-ui-types",
      "@kbn/ambient-storybook-types"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "target/**/*",
    "packaging/target/**/*",
    "packaging/example/**/*"
  ],
  "kbn_references": [
    "@kbn/core-chrome-layout-constants",
    "@kbn/core-chrome-layout-utils"
  ]
}
