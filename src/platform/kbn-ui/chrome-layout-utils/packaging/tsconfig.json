{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
    "noEmit": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": false,
    "paths": {
      "@kbn/ui-chrome-layout-constants": [
        "src/platform/kbn-ui/chrome-layout-constants/target/index.d.ts"
      ]
    }
  },
  "include": [
    "../index.ts",
    "../src/**/*.ts"
  ],
  "exclude": [
    "../src/**/*.test.*",
    "node_modules"
  ]
}
