{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
    "noEmit": true,
    "jsx": "react",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": false,
    "paths": {
      "@kbn/i18n": [
        "./react/services/i18n.tsx"
      ],
      "@kbn/i18n-react": [
        "./react/services/i18n.tsx"
      ],
      "@kbn/core-chrome-layout-utils": [
        "./react/services/core-chrome-layout-utils.ts"
      ],
      "@kbn/ui-theme": [
        "./react/services/ui-theme.ts"
      ]
    }
  },
  "include": [
    "react/**/*.ts",
    "react/**/*.tsx",
    "../grid/**/*.ts",
    "../grid/**/*.tsx",
    "../index.ts"
  ],
  "exclude": [
    "../grid/**/*.test.*",
    "../grid/**/*.stories.*",
    "../grid/**/test_utils/**",
    "node_modules"
  ]
}
