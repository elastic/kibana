{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
    "noEmit": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": false
  },
  "include": [
    "../index.ts",
    "../src/**/*.ts"
  ],
  "exclude": [
    "../src/**/*.test.*",
    "node_modules"
  ]
}
