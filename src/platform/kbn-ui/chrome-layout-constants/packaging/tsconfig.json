{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    // Type-validation only; everything (bundler resolution, module: preserve,
    // strict, esModuleInterop, skipLibCheck) is inherited from the repo base so
    // this config no longer drifts.
    "noEmit": true
  },
  "include": [
    "../index.ts",
    "../src/**/*.ts"
  ],
  "exclude": [
    "../src/**/*.test.*",
    "node_modules"
  ]
}
