{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types",
    "types": [
      "jest",
      "node",
      "react",
      "@testing-library/jest-dom",
      "@testing-library/react"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "target/**/*"
  ],
  "kbn_references": [
    "@kbn/core",
    "@kbn/i18n",
    "@kbn/i18n-react",
    "@kbn/config-schema",
    "@kbn/shared-ux-page-kibana-template",
    "@kbn/core-user-profile-browser-mocks",
    "@kbn/core-http-router-server-mocks"
  ]
}
