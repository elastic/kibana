{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types"
  },
  "include": ["*.ts", "common/**/*", "public/**/*", "server/**/*"],
  "kbn_references": [
    "@kbn/core",
    "@kbn/core-saved-objects-server",
    "@kbn/config-schema",
    "@kbn/i18n",
    "@kbn/i18n-react",
    "@kbn/data-plugin",
    "@kbn/expressions-plugin",
    "@kbn/script-panel",
    "@kbn/shared-ux-router",
    "@kbn/react-kibana-context-render",
    "@kbn/code-editor",
    "@kbn/zod"
  ],
  "exclude": ["target/**/*"]
}
