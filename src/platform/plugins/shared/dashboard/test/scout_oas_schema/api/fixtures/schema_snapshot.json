 {
  "description": "SLO Overview embeddable schema",
  "anyOf": [
   {
    "type": "object",
    "description": "SLO Single Overview embeddable schema",
    "properties": {
     "slo_id": {
      "type": "string",
      "description": "The ID of the SLO"
     },
     "slo_instance_id": {
      "type": "string",
      "description": "ID of the SLO instance. Set when the SLO uses group_by; identifies which instance to show. SLOs without group_by have * as the instance ID."
     },
     "remote_name": {
      "type": "string",
      "description": "The name of the remote SLO"
     },
     "show_all_group_by_instances": {
      "type": "boolean"
     },
     "overview_mode": {
      "type": "string",
      "enum": [
       "single"
      ]
     },
     "drilldowns": {
      "type": "array",
      "maxItems": 100,
      "items": {
       "type": "object",
       "properties": {
        "encode_url": {
         "type": "boolean",
         "description": "When true, URL is escaped using percent encoding",
         "default": true
        },
        "open_in_new_tab": {
         "type": "boolean",
         "default": true
        },
        "url": {
         "type": "string",
         "description": "Templated Url. Variables documented at https://www.elastic.co/docs/explore-analyze/dashboards/drilldowns#url-template-variable"
        },
        "label": {
         "type": "string"
        },
        "trigger": {
         "type": "string",
         "enum": [
          "on_open_panel_menu"
         ]
        },
        "type": {
         "type": "string",
         "enum": [
          "url_drilldown"
         ]
        }
       },
       "additionalProperties": false,
       "required": [
        "url",
        "label",
        "trigger",
        "type"
       ]
      }
     },
     "description": {
      "type": "string"
     },
     "hide_title": {
      "type": "boolean"
     },
     "title": {
      "type": "string"
     }
    },
    "additionalProperties": false,
    "required": [
     "slo_id",
     "overview_mode"
    ]
   },
   {
    "type": "object",
    "description": "SLO Group Overview embeddable schema",
    "properties": {
     "group_filters": {
      "type": "object",
      "properties": {
       "group_by": {
        "type": "string",
        "enum": [
         "slo.tags",
         "status",
         "slo.indicator.type"
        ]
       },
       "groups": {
        "type": "array",
        "items": {
         "type": "string"
        }
       },
       "filters": {
        "type": "array",
        "items": {
         "description": "A filter which can be a condition, group, DSL, or spatial",
         "anyOf": [
          {
           "$ref": "#/components/schemas/@kbn/as-code-filters-schema_asCodeConditionFilterSchema"
          },
          {
           "$ref": "#/components/schemas/@kbn/as-code-filters-schema_asCodeGroupFilterSchema"
          },
          {
           "$ref": "#/components/schemas/@kbn/as-code-filters-schema_asCodeDSLFilterSchema"
          },
          {
           "$ref": "#/components/schemas/@kbn/as-code-filters-schema_asCodeSpatialFilterSchema"
          }
         ]
        }
       },
       "kql_query": {
        "type": "string"
       }
      },
      "additionalProperties": false,
      "required": [
       "group_by"
      ]
     },
     "overview_mode": {
      "type": "string",
      "enum": [
       "groups"
      ]
     },
     "drilldowns": {
      "type": "array",
      "maxItems": 100,
      "items": {
       "type": "object",
       "properties": {
        "encode_url": {
         "type": "boolean",
         "description": "When true, URL is escaped using percent encoding",
         "default": true
        },
        "open_in_new_tab": {
         "type": "boolean",
         "default": true
        },
        "url": {
         "type": "string",
         "description": "Templated Url. Variables documented at https://www.elastic.co/docs/explore-analyze/dashboards/drilldowns#url-template-variable"
        },
        "label": {
         "type": "string"
        },
        "trigger": {
         "type": "string",
         "enum": [
          "on_open_panel_menu"
         ]
        },
        "type": {
         "type": "string",
         "enum": [
          "url_drilldown"
         ]
        }
       },
       "additionalProperties": false,
       "required": [
        "url",
        "label",
        "trigger",
        "type"
       ]
      }
     },
     "description": {
      "type": "string"
     },
     "hide_title": {
      "type": "boolean"
     },
     "title": {
      "type": "string"
     }
    },
    "additionalProperties": false,
    "required": [
     "overview_mode"
    ]
   }
  ]
 },
