{
  "inference.put_contextualai": {
    "url_params": {
      "error_trace": "__flag__",
      "filter_path": [],
      "human": "__flag__",
      "pretty": "__flag__",
      "timeout": [
        "30s",
        "-1",
        "0"
      ]
    },
    "url_components": {
      "task_type": [
        "rerank"
      ]
    },
    "data_autocomplete_rules": {
      "service": {
        "__one_of": [
          "contextualai"
        ]
      },
      "service_settings": {
        "api_key": "",
        "model_id": "",
        "rate_limit": {
          "requests_per_minute": ""
        }
      },
      "task_settings": {
        "instruction": "",
        "top_k": ""
      }
    },
    "methods": [
      "PUT"
    ],
    "patterns": [
      "_inference/{task_type}/{contextualai_inference_id}"
    ],
    "documentation": "https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-inference-put-contextualai",
    "documentation_serverless": "https://www.elastic.co/docs/api/doc/elasticsearch-serverless/operation/operation-inference-put-contextualai",
    "availability": {
      "stack": true,
      "serverless": true
    }
  }
}
