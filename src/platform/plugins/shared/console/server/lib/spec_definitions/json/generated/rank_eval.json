{
  "rank_eval": {
    "url_params": {
      "error_trace": "__flag__",
      "filter_path": [],
      "human": "__flag__",
      "pretty": "__flag__",
      "allow_no_indices": "__flag__",
      "expand_wildcards": [
        "all",
        "open",
        "closed",
        "hidden",
        "none"
      ],
      "ignore_unavailable": "__flag__",
      "search_type": [
        "query_then_fetch",
        "dfs_query_then_fetch"
      ]
    },
    "data_autocomplete_rules": {
      "requests": [
        {
          "id": "",
          "request": {
            "query": {
              "__scope_link": "GLOBAL.query"
            },
            "size": ""
          },
          "ratings": [
            {
              "_id": "",
              "_index": "",
              "rating": ""
            }
          ],
          "template_id": "",
          "params": {}
        }
      ],
      "metric": {
        "precision": {
          "ignore_unlabeled": "__flag__"
        },
        "recall": {},
        "mean_reciprocal_rank": {},
        "dcg": {
          "normalize": "__flag__"
        },
        "expected_reciprocal_rank": {
          "maximum_relevance": ""
        }
      }
    },
    "methods": [
      "GET",
      "POST"
    ],
    "patterns": [
      "_rank_eval",
      "{index}/_rank_eval"
    ],
    "documentation": "https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-rank-eval",
    "documentation_serverless": "https://www.elastic.co/docs/api/doc/elasticsearch-serverless/operation/operation-rank-eval",
    "availability": {
      "stack": true,
      "serverless": true
    }
  }
}
