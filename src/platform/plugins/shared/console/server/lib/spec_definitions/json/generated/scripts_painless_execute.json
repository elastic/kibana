{
  "scripts_painless_execute": {
    "url_params": {
      "error_trace": "__flag__",
      "filter_path": [],
      "human": "__flag__",
      "pretty": "__flag__"
    },
    "data_autocomplete_rules": {
      "context": {
        "__one_of": [
          "painless_test",
          "filter",
          "score",
          "boolean_field",
          "date_field",
          "double_field",
          "geo_point_field",
          "ip_field",
          "keyword_field",
          "long_field",
          "composite_field"
        ]
      },
      "context_setup": {
        "document": "",
        "index": "",
        "query": {
          "__scope_link": "GLOBAL.query"
        }
      },
      "script": {
        "source": "",
        "id": "",
        "params": {},
        "lang": {
          "__one_of": [
            "painless",
            "expression",
            "mustache",
            "java"
          ]
        },
        "options": {}
      }
    },
    "methods": [
      "GET",
      "POST"
    ],
    "patterns": [
      "_scripts/painless/_execute"
    ],
    "documentation": "https://www.elastic.co/docs/reference/scripting-languages/painless/painless-api-examples",
    "documentation_serverless": "https://www.elastic.co/docs/reference/scripting-languages/painless/painless-api-examples",
    "availability": {
      "stack": true,
      "serverless": true
    }
  }
}
