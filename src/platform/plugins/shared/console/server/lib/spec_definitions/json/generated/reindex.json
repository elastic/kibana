{
  "reindex": {
    "url_params": {
      "error_trace": "__flag__",
      "filter_path": [],
      "human": "__flag__",
      "pretty": "__flag__",
      "refresh": "__flag__",
      "requests_per_second": [
        "-1"
      ],
      "scroll": [
        "5m",
        "-1",
        "0"
      ],
      "slices": [
        "1",
        "auto"
      ],
      "max_docs": "",
      "timeout": [
        "1m",
        "-1",
        "0"
      ],
      "wait_for_active_shards": [
        "1",
        "all",
        "index-setting"
      ],
      "wait_for_completion": "__flag__",
      "require_alias": "__flag__"
    },
    "data_autocomplete_rules": {
      "conflicts": {
        "__one_of": [
          "abort",
          "proceed"
        ]
      },
      "dest": {
        "index": "",
        "op_type": {
          "__one_of": [
            "index",
            "create"
          ]
        },
        "pipeline": "",
        "routing": "",
        "version_type": {
          "__one_of": [
            "internal",
            "external",
            "external_gte"
          ]
        }
      },
      "max_docs": "",
      "script": {
        "source": "",
        "id": "",
        "params": {},
        "lang": {
          "__one_of": [
            "painless",
            "expression",
            "mustache",
            "java"
          ]
        },
        "options": {}
      },
      "source": {
        "index": "",
        "query": {
          "__scope_link": "GLOBAL.query"
        },
        "remote": {
          "connect_timeout": "",
          "headers": {},
          "host": "",
          "username": "",
          "password": "",
          "api_key": "",
          "socket_timeout": ""
        },
        "project_routing": "",
        "size": "",
        "slice": {
          "field": "",
          "id": "",
          "max": ""
        },
        "sort": "",
        "_source": {
          "exclude_vectors": "__flag__",
          "excludes": "",
          "includes": ""
        },
        "runtime_mappings": {}
      }
    },
    "methods": [
      "POST"
    ],
    "patterns": [
      "_reindex"
    ],
    "documentation": "https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-reindex",
    "documentation_serverless": "https://www.elastic.co/docs/api/doc/elasticsearch-serverless/operation/operation-reindex",
    "availability": {
      "stack": true,
      "serverless": true
    }
  }
}
