                        "diff_from_typical",
                        "time"
                      ]
                    },
                    "operator": {
                      "__one_of": [
                        "gt",
                        "gte",
                        "lt",
                        "lte"
                      ]
                    },
                    "value": ""
                  }
                ],
                "scope": {}
              }
            ],
            "detector_description": "",
            "detector_index": "",
            "exclude_frequent": {
              "__one_of": [
                "all",
