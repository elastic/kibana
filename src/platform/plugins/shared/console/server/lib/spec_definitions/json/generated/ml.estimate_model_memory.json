    ],
    "patterns": [
      "_ml/anomaly_detectors/_estimate_model_memory"
    ],
    "documentation": "https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-ml-estimate-model-memory",
    "documentation_serverless": "https://www.elastic.co/docs/api/doc/elasticsearch-serverless/operation/operation-ml-estimate-model-memory",
