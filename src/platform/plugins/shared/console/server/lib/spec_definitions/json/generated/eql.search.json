{
  "eql.search": {
    "url_params": {
      "error_trace": "__flag__",
      "filter_path": [],
      "human": "__flag__",
      "pretty": "__flag__",
      "allow_no_indices": "__flag__",
      "allow_partial_search_results": "__flag__",
      "allow_partial_sequence_results": "__flag__",
      "expand_wildcards": [
        "all",
        "open",
        "closed",
        "hidden",
        "none"
      ],
      "ccs_minimize_roundtrips": "__flag__",
      "ignore_unavailable": "__flag__",
      "keep_alive": [
        "5d",
        "-1",
        "0"
      ],
      "keep_on_completion": "__flag__",
      "wait_for_completion_timeout": [
        "-1",
        "0"
      ]
    },
    "data_autocomplete_rules": {
      "project_routing": "",
      "query": "",
      "case_sensitive": "__flag__",
      "event_category_field": "",
      "tiebreaker_field": "",
      "timestamp_field": "",
      "fetch_size": "",
      "filter": {
        "__scope_link": "GLOBAL.query"
      },
      "keep_alive": "",
      "keep_on_completion": "__flag__",
      "wait_for_completion_timeout": "",
      "allow_partial_search_results": "__flag__",
      "allow_partial_sequence_results": "__flag__",
      "size": "",
      "fields": {
        "field": "",
        "format": "",
        "include_unmapped": "__flag__"
      },
      "result_position": {
        "__one_of": [
          "tail",
          "head"
        ]
      },
      "runtime_mappings": {},
      "max_samples_per_key": ""
    },
    "methods": [
      "GET",
      "POST"
    ],
    "patterns": [
      "{index}/_eql/search"
    ],
    "documentation": "https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-eql-search",
    "documentation_serverless": "https://www.elastic.co/docs/api/doc/elasticsearch-serverless/operation/operation-eql-search",
    "availability": {
      "stack": true,
      "serverless": true
    }
  }
}
