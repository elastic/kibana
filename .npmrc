puppeteer_skip_download=true

# pnpm: emulate Kibana's flat, phantom-hoisted node_modules (parity with the
# old yarn-classic single node_modules layout).
node-linker=hoisted
hoist-pattern[]=*
public-hoist-pattern[]=*
shamefully-hoist=true

# Centralized deps: peers auto-installed at root, drift tolerated.
auto-install-peers=true
strict-peer-dependencies=false
dedupe-peer-dependents=true
